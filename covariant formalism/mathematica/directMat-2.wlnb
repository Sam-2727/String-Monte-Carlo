    },
    {
      "kind": 2,
      "value": "(DirectTracedMat[50,6,5][[1;;-2 , 1;;-2]]-TracedMat[50,6,5][[2;; , 2;;]])//FullSimplify//MatrixForm",
      "languageId": "wolfram"
    },
    {
      "kind": 2,
      "value": "Timing[DirectDetPrime[50,6,5]]\nTiming[DirectDetPrimeN[50,6,5,prec]]\nTiming[DetPrime[50,6,5]]",
