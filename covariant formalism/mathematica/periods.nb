(* Beginning of Notebook Content *)
Notebook[{
Cell[TextData[{
 "We adopt the conventions that on the disk, the vertices are at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", ",", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", "\[Pi]i", " ", 
      RowBox[{
       SubscriptBox["l", "1"], "/", "L"}]}]], ",", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", "\[Pi]i", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["l", "1"], "+", 
         SubscriptBox["l", "2"]}], ")"}], "/", "L"}]}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a0434e21-b1e3-d944-9dfd-09dd42ae1094"],
 " (and their negatives) and therefore the angle of the discretized points is \
",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", " ", "\[Pi]i", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"k", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}], "/", "L"}]}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7a60e93b-3d6d-8d4f-b5d2-11ff9dd4b878"]
}], "Text",
 CellChangeTimes->{{3.9796501548852825`*^9, 3.9796502939771156`*^9}, {
  3.979650434459999*^9, 
  3.979650440292013*^9}},ExpressionUUID->"f88c74c6-4e3b-3249-949f-\
7684e8483a36"],

Cell["\<\
The improved version of CylEqnFastOptimized, returns a List of { improvement \
prefactor, power series numerator }\
\>", "Text",
 CellChangeTimes->{{3.979238156025894*^9, 
  3.979238205580759*^9}},ExpressionUUID->"0a19a451-5963-7f4c-8fae-\
04fb72793812"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"CylEqnImproved", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "z_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"wp", "=", "100"}], ",", "shift", ",", "L", ",", "m", ",", 
      "nList", ",", "improvement", ",", "anglesL", ",", "anglesR", ",", "B", 
      ",", "gram", ",", "rhsVec", ",", "coeffs"}], "}"}], ",", 
    RowBox[{
     RowBox[{"L", "=", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"if", " ", "all", " ", "three", " ", "lengths", " ", "equal"}],
        ",", " ", 
       RowBox[{
       "there", " ", "is", " ", "no", " ", "polynomial", " ", "in", " ", 
        "the", " ", "numerator"}]}], "*)"}], 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"l1", "==", "l2", "==", "l3"}], ",", 
       RowBox[{"Return", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               SuperscriptBox["z", "2"]}], ")"}], 
             RowBox[{
              RowBox[{"-", "1"}], "/", "3"}]], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                SuperscriptBox["z", "2"], 
                RowBox[{"Exp", "[", 
                 RowBox[{"2", "*", "I", "*", 
                  RowBox[{"(", 
                   RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}]}], 
              ")"}], 
             RowBox[{
              RowBox[{"-", "1"}], "/", "3"}]], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                SuperscriptBox["z", "2"], 
                RowBox[{"Exp", "[", 
                 RowBox[{"2", "*", "I", "*", 
                  RowBox[{"(", 
                   RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l1", "/", "L"}]}], "+", 
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}]}],
               ")"}], 
             RowBox[{
              RowBox[{"-", "1"}], "/", "3"}]]}], ",", "1"}], "}"}], ",", 
         "Module"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"l1", "==", "0"}], "||", 
        RowBox[{"l2", "==", "0"}], "||", 
        RowBox[{"l3", "==", "0"}]}], ",", 
       RowBox[{"Return", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               SuperscriptBox["z", "2"]}], ")"}], 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{"l1", "+", "l3"}], ")"}]}], "/", "L"}]], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                SuperscriptBox["z", "2"], 
                RowBox[{"Exp", "[", 
                 RowBox[{"2", "*", "I", "*", 
                  RowBox[{"(", 
                   RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}]}], 
              ")"}], 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{"l1", "+", "l2"}], ")"}]}], "/", "L"}]], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{
                SuperscriptBox["z", "2"], 
                RowBox[{"Exp", "[", 
                 RowBox[{"2", "*", "I", "*", 
                  RowBox[{"(", 
                   RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l1", "/", "L"}]}], "+", 
                    RowBox[{"2", "Pi", " ", 
                    RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}]}],
               ")"}], 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{"l2", "+", "l3"}], ")"}]}], "/", "L"}]]}], ",", "1"}],
           "}"}], ",", "Module"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"m", "=", 
      RowBox[{"L", "/", "2"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"shift", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"l1", ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{"l2", ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{"l3", ",", "2"}], "]"}]}], "-", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l2", "+", "1"}], ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l3", "+", "1"}], ",", "2"}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "shift", " ", "is", " ", "1", " ", "if", " ", "all", " ", "3", " ", 
        "are", " ", "odd"}], ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], " ", "if", " ", "all", " ", "3", " ", "are", " ", 
        "even"}], ",", " ", 
       RowBox[{"0", " ", "otherwise"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"nList", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"m", "-", "shift"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesL", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "2"}], "+", 
                 RowBox[{"2", " ", "l1"}], "+", "l2", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", "m"}], "}"}]}], 
           "]"}]}], "]"}], ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesR", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", " ", "Pi", " ", 
            RowBox[{"k", "/", "L"}]}], "-", 
           RowBox[{"Pi", "/", "L"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "m"}], "}"}]}], "]"}], ",", "wp"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"improvement", "[", "angle_", "]"}], "=", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", "angle", ")"}]}], "]"}]}], ")"}], 
        RowBox[{
         RowBox[{"-", "1"}], "/", "3"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", 
             RowBox[{"angle", "-", 
              RowBox[{"(", 
               RowBox[{"2", "Pi", " ", 
                RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}], ")"}], 
        RowBox[{
         RowBox[{"-", "1"}], "/", "3"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", 
             RowBox[{"angle", "-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "Pi", " ", 
                 RowBox[{"l1", "/", "L"}]}], "+", 
                RowBox[{"2", "Pi", " ", 
                 RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}], 
         ")"}], 
        RowBox[{
         RowBox[{"-", "1"}], "/", "3"}]]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"B", "=", 
      RowBox[{"Developer`ToPackedArray", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"improvement", "[", "#", "]"}], "&"}], "/@", 
              "anglesL"}], ",", "wp"}], "]"}], "]"}], ".", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", 
            RowBox[{"Outer", "[", 
             RowBox[{"Times", ",", "anglesL", ",", "nList"}], "]"}]}], 
           "]"}]}], "+", 
         RowBox[{
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"improvement", "[", "#", "]"}], "&"}], "/@", 
              "anglesR"}], ",", "wp"}], "]"}], "]"}], ".", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", 
            RowBox[{"Outer", "[", 
             RowBox[{"Times", ",", 
              RowBox[{"Take", "[", 
               RowBox[{"anglesR", ",", 
                RowBox[{"Length", "[", "anglesL", "]"}]}], "]"}], ",", 
              "nList"}], "]"}]}], "]"}]}]}], ",", "Complex"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"gram", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "B", "]"}], ".", "B"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"gram", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "+=", 
      RowBox[{"SetPrecision", "[", 
       RowBox[{"1", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhsVec", "=", 
      RowBox[{"Developer`ToPackedArray", "[", 
       RowBox[{
        RowBox[{"UnitVector", "[", 
         RowBox[{
          RowBox[{"m", "-", "shift"}], ",", "1"}], "]"}], ",", "Complex"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"coeffs", "=", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{"gram", ",", "rhsVec"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["z", "2"]}], ")"}], 
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            SuperscriptBox["z", "2"], 
            RowBox[{"Exp", "[", 
             RowBox[{"2", "*", "I", "*", 
              RowBox[{"(", 
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{"2", "Pi", " ", 
                  RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}]}], 
          ")"}], 
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            SuperscriptBox["z", "2"], 
            RowBox[{"Exp", "[", 
             RowBox[{"2", "*", "I", "*", 
              RowBox[{"(", 
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "Pi", " ", 
                   RowBox[{"l1", "/", "L"}]}], "+", 
                  RowBox[{"2", "Pi", " ", 
                   RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}]}], 
          ")"}], 
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}]]}], ",", 
       RowBox[{"Chop", "@", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"coeffs", "[", 
            RowBox[{"[", "n", "]"}], "]"}], " ", 
           RowBox[{"z", "^", 
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"m", "-", "shift"}]}], "}"}]}], "]"}]}]}], "}"}]}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "RecCylEqnFastOptimized", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"WorkingPrecision", "->", "100"}], "}"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.979233982847079*^9, 3.979234008221951*^9}, {
  3.97923430812978*^9, 3.97923443654768*^9}, {3.979234475818928*^9, 
  3.979234499610054*^9}, {3.9792345389859486`*^9, 3.979234594687411*^9}, {
  3.979234626839756*^9, 3.979234657832186*^9}, {3.979234697208578*^9, 
  3.9792347078888664`*^9}, {3.9792353795204067`*^9, 3.979235408808021*^9}, {
  3.9792355482166843`*^9, 3.979235609438578*^9}, {3.979235708287791*^9, 
  3.979235728650957*^9}, {3.9792358724300575`*^9, 3.979235877658884*^9}, {
  3.979235927675909*^9, 3.979235930458076*^9}, {3.9792360110110435`*^9, 
  3.9792360559212627`*^9}, {3.979287372081515*^9, 3.979287381955818*^9}, {
  3.979287465596451*^9, 3.979287530604246*^9}, {3.979650314050892*^9, 
  3.979650396117214*^9}, {3.980544644037676*^9, 3.980544717511759*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"96f37867-a21a-854e-8375-e0bd01efe133"],

Cell["\<\
Calculate periods from CylEqnImproved. If f is not provided, the method first \
runs CylEqnImproved and then does the appropriate numerical integration to \
get the periods\
\>", "Text",
 CellChangeTimes->{{3.979238210407406*^9, 
  3.979238266941084*^9}},ExpressionUUID->"36a8eb77-c9c8-e74e-9978-\
86a99c5b197f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PeriodsImproved", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "f_", ",", "z_"}], "]"}], ":=",
    "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"L", "=", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ",", "\[Theta]1", 
       ",", "\[Theta]2", ",", "\[Delta]", ",", "PreCorners", ",", "Corners"}],
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[Theta]1", "=", 
       RowBox[{"2", "Pi", "*", 
        FractionBox["l1", "L"]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Theta]2", "=", 
       RowBox[{"2", "Pi", "*", 
        FractionBox["l2", "L"]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Delta]", "=", 
       FractionBox["Pi", "L"]}], ";", "\[IndentingNewLine]", 
      RowBox[{"PreCorners", "=", 
       RowBox[{"{", " ", 
        RowBox[{"1", ",", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", "*", 
           RowBox[{"(", 
            RowBox[{"\[Theta]1", "+", "\[Theta]2"}], ")"}]}], "]"}], ",", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", "*", 
           RowBox[{"(", 
            RowBox[{"Pi", "+", "\[Theta]1"}], ")"}]}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Corners", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{"N", "[", 
            RowBox[{"f", ",", "prec"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"z", ",", "0", ",", "#"}], "}"}], ",", 
           RowBox[{"WorkingPrecision", "->", "prec"}]}], "]"}], "&"}], "/@", 
        "PreCorners"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Corners", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"Corners", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"Corners", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{"Corners", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"Corners", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"Corners", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", "Module"}], "]"}],
       ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PeriodsImproved", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "l3_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"cyl", ",", "F", ",", "z"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"cyl", "=", 
       RowBox[{"CylEqnImproved", "[", 
        RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"F", "=", 
       RowBox[{
        RowBox[{"cyl", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "*", 
        RowBox[{"cyl", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"PeriodsImproved", "[", 
