Cell["\<\
Average bs the smart way, taking into account how they should be related by \
phases\
\>", "Text",
 CellChangeTimes->{{3.979240088886741*^9, 3.9792400923863297`*^9}, {
  3.980798338035385*^9, 
  3.980798351523903*^9}},ExpressionUUID->"35825c0b-f3b1-934d-8eb4-\
121adb729ca6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Averageb", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "bs_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b1", ",", "b2", ",", "b3", ",", 
       RowBox[{"L", "=", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"l1", "==", "0"}], "||", 
         RowBox[{"l2", "==", "0"}], "||", 
         RowBox[{"l3", "==", "0"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"b1", "=", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"bs", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"bs", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "*", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "I"}], "*", 
                RowBox[{"Pi", "/", "2"}]}], "]"}], "*", 
              RowBox[{"Exp", "[", 
               RowBox[{"2", " ", "I", " ", "*", "Pi", " ", "*", " ", 
                RowBox[{"l1", "/", "L"}]}], "]"}]}]}], "}"}], "//", 
           "Mean"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"b2", "=", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"bs", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"bs", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "*", 
              RowBox[{"Exp", "[", 
               RowBox[{"I", "*", 
                RowBox[{"Pi", "/", "2"}]}], "]"}], "*", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", "2"}], " ", "I", "*", "Pi", "*", 
                RowBox[{"l1", "/", "L"}]}], "]"}]}]}], "}"}], "//", 
           "Mean"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"b1", ",", "b2"}], "}"}], ",", "Module"}], "]"}], ";"}]}],
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"b1", "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"bs", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"2", " ", "I", " ", "*", "Pi", " ", "*", " ", 
             RowBox[{"l1", "/", "L"}]}], "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "2"}], " ", "I", "*", "Pi", "*", 
             RowBox[{"l3", "/", "L"}]}], "]"}]}]}], "}"}], "//", "Mean"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"b2", "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"bs", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"2", " ", "I", " ", "*", "Pi", " ", "*", " ", 
             RowBox[{"l2", "/", "L"}]}], "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "2"}], " ", "I", "*", "Pi", "*", 
             RowBox[{"l1", "/", "L"}]}], "]"}]}]}], "}"}], "//", "Mean"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"b3", "=", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"bs", "[", 
           RowBox[{"[", "3", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"2", " ", "I", " ", "*", "Pi", " ", "*", " ", 
             RowBox[{"l3", "/", "L"}]}], "]"}]}], ",", " ", 
          RowBox[{
           RowBox[{"bs", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", "*", 
             RowBox[{"Pi", "/", "3"}]}], "]"}], "*", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "2"}], " ", "I", "*", "Pi", "*", 
             RowBox[{"l2", "/", "L"}]}], "]"}]}]}], "}"}], "//", "Mean"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"b1", ",", "b2", ",", "b3"}], "}"}], ",", "Module"}], "]"}], 
      ";"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Averageb", "[", 
    RowBox[{"l1_", ",", "l2_", ",", "l3_"}], "]"}], ":=", 
   RowBox[{"Averageb", "[", 
    RowBox[{"l1", ",", "l2", ",", "l3", ",", 
     RowBox[{"Calculateb", "[", 
      RowBox[{"l1", ",", "l2", ",", "l3"}], "]"}]}], "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.979240362029077*^9, 3.979240411536976*^9}, 
   3.980798335471014*^9},ExpressionUUID->"3a8adbe7-975c-8648-8b41-\
e7adeaad6044"],

Cell["\<\
Calculate g explicitly if necessary, but this can also be done by inverting f \
and then taking a series\
\>", "Text",
 CellChangeTimes->{{3.9792409081773605`*^9, 
  3.9792409312700615`*^9}},ExpressionUUID->"1c4e066f-0b94-7943-aa6d-\
422ee9754134"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"RecCylEqnImproved", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "z_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"wp", "=", "100"}], ",", "shift", ",", "L", ",", "m", ",", 
      "nList", ",", "improvement", ",", "anglesL", ",", "anglesR", ",", "B", 
      ",", "gram", ",", "rhsVec", ",", "coeffs"}], "}"}], ",", 
    RowBox[{
     RowBox[{"L", "=", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"m", "=", 
      RowBox[{"L", "/", "2"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"shift", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"l1", ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{"l2", ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{"l3", ",", "2"}], "]"}]}], "-", 
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l2", "+", "1"}], ",", "2"}], "]"}], "*", 
        RowBox[{"Mod", "[", 
         RowBox[{
          RowBox[{"l3", "+", "1"}], ",", "2"}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "shift", " ", "is", " ", "1", " ", "if", " ", "all", " ", "3", " ", 
        "are", " ", "odd"}], ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], " ", "if", " ", "all", " ", "3", " ", "are", " ", 
        "even"}], ",", " ", 
       RowBox[{"0", " ", "otherwise"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"nList", "=", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"m", "-", "shift"}], "]"}], "-", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"anglesL", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "2"}], "+", 
                 RowBox[{"2", " ", "l1"}], "+", "l2", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k"}], 
                ")"}], "/", "L"}]}], "-", 
             RowBox[{"Pi", "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", "m"}], "}"}]}], 
           "]"}]}], "]"}], ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesR", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"2", " ", "Pi", " ", 
            RowBox[{"k", "/", "L"}]}], "-", 
           RowBox[{"Pi", "/", "L"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "m"}], "}"}]}], "]"}], ",", "wp"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"improvement", "[", "angle_", "]"}], "=", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", "angle", ")"}]}], "]"}]}], ")"}], 
        RowBox[{"1", "/", "3"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", 
             RowBox[{"angle", "-", 
              RowBox[{"(", 
               RowBox[{"2", "Pi", " ", 
                RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}], ")"}], 
        RowBox[{"1", "/", "3"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", "*", "I", "*", 
            RowBox[{"(", 
             RowBox[{"angle", "-", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "Pi", " ", 
                 RowBox[{"l1", "/", "L"}]}], "+", 
                RowBox[{"2", "Pi", " ", 
                 RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}], 
         ")"}], 
        RowBox[{"1", "/", "3"}]]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"B", "=", 
      RowBox[{"Developer`ToPackedArray", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"improvement", "[", "#", "]"}], "&"}], "/@", 
              "anglesL"}], ",", "wp"}], "]"}], "]"}], ".", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", 
            RowBox[{"Outer", "[", 
             RowBox[{"Times", ",", "anglesL", ",", "nList"}], "]"}]}], 
           "]"}]}], "+", 
         RowBox[{
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"improvement", "[", "#", "]"}], "&"}], "/@", 
              "anglesR"}], ",", "wp"}], "]"}], "]"}], ".", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", 
            RowBox[{"Outer", "[", 
             RowBox[{"Times", ",", 
              RowBox[{"Take", "[", 
               RowBox[{"anglesR", ",", 
                RowBox[{"Length", "[", "anglesL", "]"}]}], "]"}], ",", 
              "nList"}], "]"}]}], "]"}]}]}], ",", "Complex"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"gram", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "B", "]"}], ".", "B"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"gram", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "+=", 
      RowBox[{"SetPrecision", "[", 
       RowBox[{"1", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhsVec", "=", 
      RowBox[{"Developer`ToPackedArray", "[", 
       RowBox[{
        RowBox[{"UnitVector", "[", 
         RowBox[{
          RowBox[{"m", "-", "shift"}], ",", "1"}], "]"}], ",", "Complex"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"coeffs", "=", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{"gram", ",", "rhsVec"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SuperscriptBox["z", "2"]}], ")"}], 
         RowBox[{"1", "/", "3"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            SuperscriptBox["z", "2"], 
            RowBox[{"Exp", "[", 
             RowBox[{"2", "*", "I", "*", 
              RowBox[{"(", 
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{"2", "Pi", " ", 
                  RowBox[{"l1", "/", "L"}]}], ")"}]}], ")"}]}], "]"}]}]}], 
          ")"}], 
         RowBox[{"1", "/", "3"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            SuperscriptBox["z", "2"], 
            RowBox[{"Exp", "[", 
             RowBox[{"2", "*", "I", "*", 
              RowBox[{"(", 
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"2", "Pi", " ", 
                   RowBox[{"l1", "/", "L"}]}], "+", 
                  RowBox[{"2", "Pi", " ", 
                   RowBox[{"l2", "/", "L"}]}]}], ")"}]}], ")"}]}], "]"}]}]}], 
          ")"}], 
         RowBox[{"1", "/", "3"}]]}], ",", 
       RowBox[{"Chop", "@", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"coeffs", "[", 
            RowBox[{"[", "n", "]"}], "]"}], " ", 
           RowBox[{"z", "^", 
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"m", "-", "shift"}]}], "}"}]}], "]"}]}]}], "}"}]}]}], 
   "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "RecCylEqnFastOptimized", "]"}], "=", 
   RowBox[{"{", 
    RowBox[{"WorkingPrecision", "->", "100"}], "}"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.979240570669899*^9, 3.97924059801746*^9}, {
   3.979240865700945*^9, 3.979240889748987*^9}, {3.979650457979313*^9, 
   3.979650493185612*^9}, 3.9798296395596256`*^9},
 CellLabel->"In[28]:=",ExpressionUUID->"fc3f0545-dab6-334f-8727-0e7efd7a857a"],

Cell[CellGroupData[{

Cell["Old Methods", "Section",
 CellChangeTimes->{{3.979240982166565*^9, 
  3.9792409841146393`*^9}},ExpressionUUID->"bbfdebb4-98dd-a94a-a806-\
b084f84a3401"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CylEqnFastOptimized", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "CylEqnFastOptimized", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"WorkingPrecision", "->", "200"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"CylEqnFastOptimized", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "z_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"wp", "=", "100"}], ",", "L", ",", "m", ",", "nList", ",", 
      "anglesL", ",", "anglesR", ",", "B", ",", "gram", ",", "rhsVec", ",", 
      "coeffs"}], "}"}], ",", 
    RowBox[{
     RowBox[{"L", "=", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"m", "=", 
      RowBox[{"L", "/", "2"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nList", "=", 
      RowBox[{"Range", "[", "m", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesL", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k"}], 
               ")"}], "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"L", "/", "2"}], "+", 
                RowBox[{"2", " ", "l1"}], "+", "l2", "+", "1", "-", "k"}], 
               ")"}], "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k"}], ")"}],
               "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
