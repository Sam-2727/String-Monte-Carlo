   3.979286545260432*^9, {3.979475246744961*^9, 3.97947533869635*^9}, {
   3.979475372235918*^9, 3.979475398224216*^9}, {3.979475510905844*^9, 
   3.979475524178545*^9}, {3.979643638931196*^9, 3.979643653925354*^9}, {
   3.979650126838012*^9, 3.979650145168913*^9}, {3.979650416602905*^9, 
   3.979650427842432*^9}, {3.9805448841427097`*^9, 3.980544913058841*^9}, {
