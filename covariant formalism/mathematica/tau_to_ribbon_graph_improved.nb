  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"toFundamental", "[", 
    RowBox[{"z_", ",", "\[Tau]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p1", ",", "p2", ",", "A", ",", "\[Alpha]", ",", "\[Beta]"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"p1", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"p2", "=", "\[Tau]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "[", "p1", "]"}], ",", 
           RowBox[{"Re", "[", "p2", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Im", "[", "p1", "]"}], ",", 
           RowBox[{"Im", "[", "p2", "]"}]}], "}"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Alpha]", ",", "\[Beta]"}], "}"}], "=", 
