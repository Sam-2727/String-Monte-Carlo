        RowBox[{"A", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Re", "[", "z", "]"}], ",", 
           RowBox[{"Im", "[", "z", "]"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Alpha]", "=", 
       RowBox[{"\[Alpha]", "-", 
        RowBox[{"Floor", "[", "\[Alpha]", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"\[Beta]", "=", 
