      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Alpha]", " ", "p1"}], "+", 
       RowBox[{"\[Beta]", " ", "p2"}]}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"wpPreimagesOnTorus", "[", 
    RowBox[{
     RowBox[{"v_", "?", "NumericQ"}], ",", 
     RowBox[{"\[Tau]_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
