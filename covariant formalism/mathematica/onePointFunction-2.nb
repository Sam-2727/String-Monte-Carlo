Cell[CellGroupData[{

Cell["Stress tensor 1-pt function", "Subsection",
 CellChangeTimes->{{3.9780083750291996`*^9, 
  3.978008379428772*^9}},ExpressionUUID->"ec9a493e-b5d3-a54b-8cf3-\
fea9ac621684"],

Cell[TextData[{
 "Equivalent of the C matrix but for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "m"], 
    SubscriptBox["X", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9c2f0d77-1c30-5e4e-b49b-cf8c22669ddf"],
 " instead of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "1"], 
    SubscriptBox["X", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5c57e5fb-5a14-a045-bc83-4f74b8dfb1e9"]
}], "Text",
 CellChangeTimes->{{3.978008387841549*^9, 
  3.9780084512473164`*^9}},ExpressionUUID->"08d40c16-fcf7-ad46-8850-\
0e1dd7295966"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"**", 
   RowBox[{
   "*", "CHECK", " ", "THE", " ", "SIGN", " ", "in", " ", "the", " ", 
    "exponent"}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.9785302521821384`*^9, 
  3.978530269605673*^9}},ExpressionUUID->"60b518e4-cf25-894f-a23b-\
6941a39a4a2c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectCMat", "[", 
   RowBox[{"L_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"DirectFMat", "[", 
   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "m", "]"}], "!"}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "n", "]"}], "!"}], ")"}]}], 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "*", "#2"}], "+", 
            RowBox[{"n", "*", "#3"}]}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DirectCMatN", "[", 
   RowBox[{"L_", ",", "m_", ",", "n_", ",", "NPrec_"}], "]"}], ":=", 
  RowBox[{"DirectFMatN", "[", 
   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "m", "]"}], "!"}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "n", "]"}], "!"}], ")"}]}], 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "*", "#2"}], "+", 
            RowBox[{"n", "*", "#3"}]}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}], ",", "NPrec"}], "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008457784712*^9, 3.978008532203291*^9}, 
   3.978370019056921*^9, {3.9785301861958847`*^9, 3.9785301875362415`*^9}, {
   3.978531439115196*^9, 
   3.978531458518219*^9}},ExpressionUUID->"6a86c7c5-d6f7-364d-affd-\
65c5d22fe29b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedCMat", "[", 
   RowBox[{"L_", ",", "m_", ",", "n_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L", ",", "l1", ",", "l2", ",", 
    RowBox[{"DirectCMat", "[", 
