  3.9774135519668846`*^9, 3.9774135626345463`*^9}},
 CellLabel->
  "In[367]:=",ExpressionUUID->"699aa3f7-027e-7144-b8b1-1f6148d33c6c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"make", " ", "sure", " ", "l1"}], ",", "l2", ",", 
    RowBox[{
     RowBox[{"l3", " ", "are", " ", 
      RowBox[{"odd", ".", " ", "Here"}], " ", "we", " ", "use", " ", "l1"}], 
     "=", 
     RowBox[{"l2", "=", "k"}]}], ",", " ", 
    RowBox[{"l3", "=", 
     RowBox[{
      RowBox[{"L", "/", "2"}], "-", 
      RowBox[{"2", "k", " ", "so", " ", 
       RowBox[{"it", "'"}], "s", " ", "important", " ", "that", " ", 
       RowBox[{"L", "/", "2"}], " ", "and", " ", "k", " ", "are", " ", 
       "odd"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"L1", "=", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Print", "[", "k", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"findTrCA", "[", 
       RowBox[{"setL", ",", "k", ",", "k", ",", "AMat", ",", "CMat"}], 
       "]"}]}], "\[IndentingNewLine]", ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "77", ",", "2"}], "}"}]}], 
    "]"}]}]}]], "Input",
