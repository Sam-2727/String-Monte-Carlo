Running tests to see if tr(\\wt{C} \\wt{A}^{-1}) \\propto |\\hat{f}(0)|^2/ \
\[Tau]2\
\>", "Text",
 CellChangeTimes->{{3.9774138802361717`*^9, 3.977413882715456*^9}, {
  3.977415287022087*^9, 
  3.977415325299959*^9}},ExpressionUUID->"4d13b876-766b-9a4b-b3ff-\
39104ba63ce7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"setL", "=", "310"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"prec", "=", "15"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Since", " ", "we", " ", "want", " ", "to", " ", "test", " ", "different",
      " ", "\[Tau]", " ", "at", " ", "the", " ", "same", " ", "L"}], ",", " ", 
    RowBox[{
    "useful", " ", "to", " ", "store", " ", "the", " ", "precursor", " ", 
     "matrices"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AMat", "=", 
   RowBox[{"DirectMatN", "[", 
    RowBox[{"setL", ",", "prec"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CMat", "=", 
   RowBox[{"DirectCMatN", "[", 
    RowBox[{"setL", ",", "prec"}], "]"}]}], ";"}]}], "Input",
