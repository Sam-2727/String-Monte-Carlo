Cell[CellGroupData[{

Cell[TextData[{
 "Calculating tr(",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["CA", 
    RowBox[{"-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d0658364-e0ac-524e-8c23-490a88def7f6"],
 "):"
}], "Subsection",
 CellChangeTimes->{{3.977413190269081*^9, 3.977413192168478*^9}, {
   3.977413287423609*^9, 3.9774132996788197`*^9}, 
   3.9774135555385857`*^9},ExpressionUUID->"d5f02c8e-0d78-c840-845b-\
c86c1df84979"],

Cell["\<\
For a given L, l1, l2 this will find \\wt{C}, \\wt{A}, and f. Then print \
tr(\\wt{C} \\wt{A}^{-1}), then print the periods, normalized so that the \
period of the a cycle is 1. It finally outputs 
{\[Tau]2, tr( \\wt{C} \\wt{A}^{-1}) / | \\hat{f}(0)|^2}\
\>", "Text",
 CellChangeTimes->{{3.977413571692646*^9, 3.9774135804450283`*^9}, {
  3.9774136616134377`*^9, 
  3.9774138492233047`*^9}},ExpressionUUID->"3e34a19e-079f-044b-8f18-\
524dff4a387c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"findTrCA", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "AMat_", ",", "CMat_"}], "]"}], 
  ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "l3", ",", "redA", ",", "invA", ",", "redC", ",", "tr", ",", "f", ",", 
      "per", ",", "perRed"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"l3", "=", 
      RowBox[{
       RowBox[{"L", "/", "2"}], "-", "l1", "-", "l2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"redA", "=", 
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l1", ",", "l2", ",", "AMat"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "1", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"redC", "=", 
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l1", ",", "l2", ",", "CMat"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "2", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"invA", "=", 
      RowBox[{"Inverse", "[", "redA", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "3", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      RowBox[{"CylEqnFastOptimized", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "4", "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"tr", "=", 
       RowBox[{"Tr", "[", 
        RowBox[{"redC", " ", ".", " ", "invA"}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"per", "=", 
      RowBox[{"PeriodsFastGivenF", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", 
        RowBox[{"l1", "/", "2"}], ",", 
        RowBox[{"l2", "/", "2"}], ",", 
        RowBox[{"l3", "/", "2"}], ",", "f", ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"perRed", "=", 
       RowBox[{"per", "/", 
        RowBox[{"per", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"perRed", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}], "]"}], ";"}], "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Note", " ", "that", " ", 
       RowBox[{"1", "/", 
        RowBox[{"per", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], " ", 
       RowBox[{"is", " ", "\\", "hat"}], 
       RowBox[{"{", "f", "}"}], 
       RowBox[{"(", "0", ")"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Im", "[", 
          RowBox[{"perRed", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
         RowBox[{"Re", "[", 
          RowBox[{"tr", "*", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"per", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "^", "2"}]}], "]"}]}], 
        "}"}], ",", "Module"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9774135228085823`*^9, 3.9774135499785213`*^9}, {
  3.97741361128957*^9, 3.977413657816675*^9}, {3.977414104215044*^9, 
  3.977414129050173*^9}, {3.9774142367361794`*^9, 3.977414243177748*^9}},
 CellLabel->
  "In[375]:=",ExpressionUUID->"a8aca26d-a8d8-6640-b8ba-5a20ce0e26c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "if", " ", "no", " ", "precursor", " ", "matrices", " ", "provided"}], 
    ",", " ", 
    RowBox[{"generate", " ", "them", " ", "first"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"findTrCA", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
   RowBox[{"findTrCA", "[", 
    RowBox[{"L", ",", "l1", ",", "l2", ",", 
     RowBox[{"DirectMatN", "[", 
      RowBox[{"L", ",", "prec"}], "]"}], ",", 
     RowBox[{"DirectCMatN", "[", 
      RowBox[{"L", ",", "prec"}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.977414270772852*^9, 3.9774143487285957`*^9}},
 CellLabel->
  "In[376]:=",ExpressionUUID->"5d896c51-109a-a041-ab3b-c306a939eb9e"],

