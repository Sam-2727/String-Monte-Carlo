   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{"I", "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"#2", "-", "#3"}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}], ",", "NPrec"}], "]"}]}]], "Input",
 InitializationCell->True,
