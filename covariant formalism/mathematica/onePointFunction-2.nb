Cell["\<\
Given some function f_L[k,l] generate the corresponding matrix\
\>", "Text",
 CellChangeTimes->{{3.978008104572199*^9, 3.9780081423182716`*^9}, 
   3.978008183200157*^9},ExpressionUUID->"39c87231-2f43-8d45-8c8d-\
270e5218924a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectFMat", "[", 
   RowBox[{"L_", ",", "f_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
         RowBox[{"f", "[", 
          RowBox[{"L", ",", "k", ",", "l"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008145795967*^9, 3.9780081875044513`*^9}},
 CellLabel->"In[46]:=",ExpressionUUID->"16ba3481-ba77-e446-8219-5935d22def9d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectFMatN", "[", 
   RowBox[{"L_", ",", "f_", ",", "NPrec_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"f", "[", 
            RowBox[{"L", ",", "k", ",", "l"}], "]"}], ",", "NPrec"}], "]"}]}],
         ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008199087793*^9, 3.978008212656801*^9}},
 CellLabel->"In[47]:=",ExpressionUUID->"a7aa48f4-b40e-ba4f-b9c9-13141227c67d"],

Cell["\<\
Similar to directMat.nb for the A matrix, generate the LxL precursor matrix \
for the C matrix\
\>", "Text",
 CellChangeTimes->{{3.9774122024154873`*^9, 
  3.9774122242596874`*^9}},ExpressionUUID->"cfa5e4ca-daf2-fa41-851d-\
5213bd8e457f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectCMat", "[", "L_", "]"}], ":=", 
  RowBox[{"DirectFMat", "[", 
   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox["1", 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{"I", "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"#2", "-", "#3"}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9780082425131474`*^9, 3.9780082707068024`*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"c97741f8-1b79-1b4d-9a6a-c2f0d1d0ff6c"],

