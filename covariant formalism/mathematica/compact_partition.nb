  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "l", ",", "i", ",", "j", ",", "tempMat", ",", "tempW", ",", 
      "segments", ",", "segmentMaps"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", "Mat"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tempW", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"L", "/", "2"}], ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segments", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "l1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", 
          RowBox[{"l1", "+", "l2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segmentMaps", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
