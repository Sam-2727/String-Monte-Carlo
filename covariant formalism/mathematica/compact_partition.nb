Cell[BoxData[{
 RowBox[{
  RowBox[{"CylEqn", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "z_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"L", "=", 
       RowBox[{"2", 
        RowBox[{"(", 
         RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ",", "CylForm", ",",
       "n", ",", "eqns", ",", "solsub"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"CylForm", "[", "\[Theta]_", "]"}], ":=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"A", "[", "n", "]"}], " ", 
         RowBox[{"E", "^", 
          RowBox[{"(", 
           RowBox[{"I", " ", "n", " ", "\[Theta]"}], ")"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "1", ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
     RowBox[{"eqns", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"A", "[", "1", "]"}], "==", "1"}], "}"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"CylForm", "[", 
              RowBox[{"2", "Pi", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], 
                 ")"}], "/", "L"}]}], "]"}], "==", 
             RowBox[{"-", 
              RowBox[{"CylForm", "[", 
               RowBox[{"2", "Pi", " ", 
                RowBox[{"k1", "/", "L"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"CylForm", "[", 
              RowBox[{"2", "Pi", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"L", "/", "2"}], "+", 
                  RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], 
                 ")"}], "/", "L"}]}], "]"}], "==", 
             RowBox[{"-", 
              RowBox[{"CylForm", "[", 
               RowBox[{"2", "Pi", " ", 
                RowBox[{"k2", "/", "L"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k2", ",", 
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"CylForm", "[", 
              RowBox[{"2", "Pi", " ", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], 
                 ")"}], "/", "L"}]}], "]"}], "==", 
             RowBox[{"-", 
              RowBox[{"CylForm", "[", 
               RowBox[{"2", "Pi", " ", 
                RowBox[{"k3", "/", "L"}]}], "]"}]}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k3", ",", 
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
              RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"A", "[", "n", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"WorkingPrecision", "\[Rule]", "20"}]}], "}"}]}], ";", 
     RowBox[{"solsub", "=", 
      RowBox[{"NSolve", " ", "@@", " ", "eqns"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"A", "[", "n", "]"}], " ", 
          RowBox[{"z", "^", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}], "/.", 
       RowBox[{"solsub", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "//", "Chop"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
