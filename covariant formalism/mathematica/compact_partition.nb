Cell[TextData[{
 "Testing the partition for compact boson and free fermions. In our \
convention \[Alpha]\[CloseCurlyQuote] = 1, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "fermion"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a16fd951-de22-496f-a748-6b9a430dafc3"],
 "[\[Tau]] = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "compact"], "[", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[Sqrt]", "2"}]], ",", "\[Tau]"}], "]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d8014ca6-4a3e-4cca-84cf-a12122a0bdeb"],
