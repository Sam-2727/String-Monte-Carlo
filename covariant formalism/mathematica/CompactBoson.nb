            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempT", ",", "Module"}], "]"}], ";"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.9781859449416437`*^9, 3.978185961948132*^9}, {
   3.978187214683312*^9, 3.978187337145425*^9}, {3.9781875451180162`*^9, 
   3.978187626008958*^9}, {3.978187690481238*^9, 3.978187722879407*^9}, 
   3.978187840182291*^9, 3.978187887328116*^9, {3.978188287804513*^9, 
   3.978188291390427*^9}, 3.97818841616765*^9, {3.978190840528757*^9, 
   3.9781908931581163`*^9}, {3.9781915236503572`*^9, 3.978191527201763*^9}, 
   3.978192439266992*^9, {3.978192840273178*^9, 3.9781928507665377`*^9}, {
   3.9791368869626627`*^9, 3.979136887208267*^9}},
 Background->GrayLevel[0.85],
 CellLabel->
  "In[267]:=",ExpressionUUID->"f47d2dbc-8a26-4f5f-8668-94dcb5413d1e"],

Cell[TextData[{
 "Second piece of the matrix ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "ij"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e4873ea6-5908-4c22-87cd-775dcae6d916"],
 ":\nWe compute the sum ",
 Cell[BoxData[
  RowBox[{
   UnderscriptBox["\[Sum]", 
    RowBox[{"m", ",", "n", ",", "k", ",", "l"}]], 
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      SuperscriptBox["A", 
       RowBox[{"'", "-", "1"}]], ")"}], "kl"], 
    SubscriptBox["W", "km"], 
    SubscriptBox["W", "ln"]}]}]],ExpressionUUID->
  "7eece599-080e-494d-b720-d2f2fa425f91"],
 " by the following:  First compute the vector ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["u", 
    RowBox[{"i", ",", "k"}]], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", 
     RowBox[{"m", "\[Element]", 
      RowBox[{"seg", " ", "i"}]}]], 
    SubscriptBox["W", "km"]}]}]],ExpressionUUID->
  "3b975ff2-63e8-4a5a-905f-a421ac0c9f6c"],
 ". The sum can then be expressed as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      SubscriptBox["u", "i"], "T"], 
     SuperscriptBox["A", 
      RowBox[{"'", "-", "1"}]], 
     SubscriptBox["u", "j"]}], "=", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["u", "i"], "T"], 
     SubscriptBox["w", "j"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dcf68e50-500d-4c8e-833f-ed9614a1510b"],
 ", and the vector  ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["w", "j"], "=", 
   RowBox[{
    SuperscriptBox["A", 
     RowBox[{"'", "-", "1"}]], 
    SubscriptBox["u", "j"]}]}]],ExpressionUUID->
  "9b213882-3713-4509-a869-8a825d59a116"],
 " can then be computed by solving the linear system ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"A", "'"}], 
     SubscriptBox["w", "j"]}], "=", 
    SubscriptBox["u", "j"]}], TraditionalForm]],ExpressionUUID->
  "2cef857e-78df-43bc-b2e1-ded8151abe1a"],
 ". I guess this is faster than finding the inverse directly."
}], "Text",
 CellChangeTimes->{{3.9781855337174253`*^9, 3.9781858952565393`*^9}, {
  3.9781877731339893`*^9, 3.978187787909904*^9}, {3.978189069801263*^9, 
  3.978189079784553*^9}, {3.978192998187196*^9, 
  3.978193004214365*^9}},ExpressionUUID->"18fedf9b-e005-4274-b4af-\
1b5813899bf0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MatTSecondPart", "[", 
   RowBox[{
   "L_", ",", "l1_", ",", "l2_", ",", "Mat_", ",", "W_", ",", "Aprime_"}], 
   "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "i", ",", "j", ",", "k", ",", "tempMat", ",", "segments", ",", 
      "segmentMaps", ",", "tempu", ",", "tempw", ",", "solvedw", ",", 
      "tempT"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", "Mat"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tempT", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"tempu", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"tempw", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segments", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "l1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", 
          RowBox[{"l1", "+", "l2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segmentMaps", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", 
           RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "#1"}], ",", 
            "L", ",", "1"}], "]"}], ")"}], "&"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"The", " ", "vector", " ", "u"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"tempu", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "k"}], "]"}], "]"}], "=", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"W", "[", 
              RowBox[{"[", 
               RowBox[{"k", ",", "m"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"m", ",", 
               RowBox[{"segments", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{"segments", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}]}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Solving", " ", "linear", " ", "system", " ", "to", " ", "find", " ",
           "vector", " ", "w"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"solvedw", "=", 
         RowBox[{"LinearSolve", "[", 
          RowBox[{"Aprime", ",", 
           RowBox[{"tempu", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"tempw", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "k"}], "]"}], "]"}], "=", 
           RowBox[{"solvedw", "[", 
            RowBox[{"[", "k", "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"The", " ", "second", " ", "part", " ", "of", " ", 
         SubscriptBox["T", "ij"]}], ",", " ", 
        RowBox[{"note", " ", "that", " ", "I", " ", 
         RowBox[{"didn", "'"}], "t", " ", "include", " ", "the", " ", "minus",
          " ", "sign"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"tempT", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "[", 
          RowBox[{"[", "j", "]"}], "]"}], "=", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"tempu", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "k"}], "]"}], "]"}], "*", 
            RowBox[{"tempw", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "k"}], "]"}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "1", ",", 
             RowBox[{
              RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempT", ",", "Module"}], "]"}], ";"}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 CellChangeTimes->{{3.978187801770135*^9, 3.978187891908914*^9}, {
   3.978188187271912*^9, 3.97818830913098*^9}, {3.9781883456236067`*^9, 
   3.978188441817174*^9}, {3.978189280906797*^9, 3.978189421788192*^9}, {
   3.978189452798347*^9, 3.978189457882702*^9}, {3.978189536142767*^9, 
   3.978189538426969*^9}, {3.978190272463036*^9, 3.978190562417388*^9}, {
   3.978190632615287*^9, 3.9781906330179777`*^9}, {3.9781907833469143`*^9, 
   3.978190786308255*^9}, {3.978190825926798*^9, 3.9781908271473703`*^9}, {
   3.9781915756123543`*^9, 3.978191607921673*^9}, {3.9781917498560257`*^9, 
   3.9781917869857397`*^9}, 3.9781918377192287`*^9, {3.9781919123540163`*^9, 
   3.9781919630138073`*^9}, {3.978192208242934*^9, 3.978192213730666*^9}, {
   3.978192248903054*^9, 3.9781922646382523`*^9}, {3.9781923181021633`*^9, 
   3.978192324941427*^9}, {3.978192450511539*^9, 3.978192457745513*^9}, {
   3.978192726502263*^9, 3.9781927267806683`*^9}, {3.978192825217452*^9, 
   3.978192825582315*^9}, {3.97819349231038*^9, 3.978193492494216*^9}},
 Background->GrayLevel[0.85],
 CellLabel->
  "In[268]:=",ExpressionUUID->"7667bdfc-f04e-4290-afbd-ef4a83cf1a06"],

Cell["\<\
Moment of truth... SiegelTheta need the input to be a symmetric matrix, so we \
need to first symmetrize T.\
\>", "Text",
 CellChangeTimes->{{3.9781910330094347`*^9, 3.97819104029496*^9}, {
  3.978191410111293*^9, 
  3.978191434293705*^9}},ExpressionUUID->"56f54655-742c-4fcc-ace3-\
6d257229517a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Symm", "[", "T_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"T", "+", 
     RowBox[{"Transpose", "[", "T", "]"}]}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Tduality", "[", 
    RowBox[{"R_", ",", "T_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"R", " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "4"}], " ", "Pi", " ", 
         RowBox[{"R", "^", "2"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s1", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s1", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ")"}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"s1", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s2", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}]}], "]"}]}], "-", 
    RowBox[{
     FractionBox["1", "R"], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "4"}], " ", "Pi", " ", 
         FractionBox["1", 
          RowBox[{"R", "^", "2"}]], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s1", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s1", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ")"}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"s1", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s2", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}]}], "]"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"RPrime", "[", 
    RowBox[{"R_", ",", "T_"}], "]"}], ":=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"4", "*", "R", "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Det", "[", "T", "]"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"TdualityTest2", "[", 
    RowBox[{"R_", ",", "T_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"R", " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "4"}], " ", "Pi", " ", 
         RowBox[{"R", "^", "2"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s1", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s1", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ")"}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"s1", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s2", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}]}], "]"}]}], "-", 
    RowBox[{
     RowBox[{"RPrime", "[", 
      RowBox[{"R", ",", "T"}], "]"}], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "4"}], " ", "Pi", " ", 
         RowBox[{
          RowBox[{"RPrime", "[", 
           RowBox[{"R", ",", "T"}], "]"}], "^", "2"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s1", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s1", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s1", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}]}], "+", 
           RowBox[{"s2", " ", "s2", " ", 
            RowBox[{"T", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}]}], ")"}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"s1", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s2", ",", 
         RowBox[{"-", "20"}], ",", "20", ",", "1"}], "}"}]}], "]"}]}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.978191041913362*^9, 3.978191135363516*^9}, {
   3.978191438204253*^9, 3.9781914703748627`*^9}, 3.979136950392419*^9},
 Background->GrayLevel[0.85],
 CellLabel->
  "In[269]:=",ExpressionUUID->"797aa768-3c37-4b08-bf25-ee54fff65241"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Now we actually run the code", "Section",
 CellChangeTimes->{{3.978189750564001*^9, 
  3.978189756342408*^9}},ExpressionUUID->"eacdf34d-1e02-4126-8fe2-\
92485a222fe4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "k", ",", "L", ",", "l1", ",", "l2", ",", "Mat", ",", "Aprime", ",", "W", 
     ",", "T1", ",", "T2", ",", "R", ",", "res", ",", " ", "T", ",", " ", 
     "Tred", ",", "sgn"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k", "=", "5"}], ";", "\[IndentingNewLine]", 
    RowBox[{"L", "=", 
     RowBox[{"100", "*", "k"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"l1", "=", 
     RowBox[{"5", "*", "k"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"l2", "=", 
     RowBox[{"30", "*", "k"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"R", "=", "1.4"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Mat", "=", 
     RowBox[{
      RowBox[{"DirectMatN", "[", 
       RowBox[{"L", ",", "prec"}], "]"}], "/", "2"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Aprime", "=", 
     RowBox[{"MatAp", "[", 
      RowBox[{"L", ",", "l1", ",", "l2", ",", "Mat"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"W", "=", 
     RowBox[{"MatW", "[", 
      RowBox[{"L", ",", "l1", ",", "l2", ",", "Mat"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"T1", "=", 
     RowBox[{"MatTFirstPart", "[", 
      RowBox[{"L", ",", "l1", ",", "l2", ",", "Mat"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"T2", "=", 
     RowBox[{"MatTSecondPart", "[", 
      RowBox[{
      "L", ",", "l1", ",", "l2", ",", "Mat", ",", "W", ",", "Aprime"}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"T", "=", 
     RowBox[{"Symm", "[", 
      RowBox[{"T1", "-", "T2"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"sgn", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Tred", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
