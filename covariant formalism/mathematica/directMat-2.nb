 RowBox[{
  RowBox[{
   RowBox[{"BnmatFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "n_", ",", 
     RowBox[{"NPrec_", " ", ":", " ", "prec"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
