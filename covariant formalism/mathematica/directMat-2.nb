         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k3", ",", 
             RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
             RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"kernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
