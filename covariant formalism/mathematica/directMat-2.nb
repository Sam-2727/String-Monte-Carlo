Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"{", 
    RowBox[{"L", ",", 
     RowBox[{
      RowBox[{"DetPrime", "[", 
       RowBox[{"L", ",", 
        RowBox[{"L", "/", "4"}], ",", 
        RowBox[{"L", "/", "4"}]}], "]"}], "/", 
      RowBox[{"DetPrime", "[", 
       RowBox[{"L", ",", 
        RowBox[{
         RowBox[{"L", "/", "4"}], "-", "1"}], ",", 
        RowBox[{
         RowBox[{"L", "/", "4"}], "-", "1"}]}], "]"}]}]}], "}"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"table", ",", "fit", ",", "P1", ",", "P2"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"table", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"elt", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"elt", "[", 
            RowBox[{"[", "5", "]"}], "]"}], "/", 
           RowBox[{"elt", "[", 
            RowBox[{"[", "4", "]"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"elt", ",", "TestTable"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"P1", "=", 
      RowBox[{"ListPlot", "[", 
       RowBox[{"table", ",", 
        RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fit", "=", 
      RowBox[{"FindFit", "[", 
       RowBox[{"table", ",", 
        RowBox[{"a", "+", 
         RowBox[{"b", "/", 
          RowBox[{"L", "^", "c"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", "L"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"P2", "=", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "+", 
          RowBox[{"b", "/", 
           RowBox[{"L", "^", "c"}]}]}], "/.", "fit"}], ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "10", ",", "1200"}], "}"}], ",", 
        RowBox[{"PlotStyle", "->", "Red"}], ",", 
        RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"Show", "[", 
       RowBox[{"P1", ",", "P2"}], "]"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"ListLogPlot", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"elt", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"elt", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "/", 
                  RowBox[{"elt", "[", 
                   RowBox[{"[", "3", "]"}], "]"}]}], "-", "a"}], ")"}], "/", 
               "b"}], "/.", "fit"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"elt", ",", "TestTable"}], "}"}]}], "]"}], "]"}], "]"}], 
       ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"fit", ",", "Module"}], "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
