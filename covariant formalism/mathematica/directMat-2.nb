             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"m", "*", 
                  RowBox[{"repSites", "[", 
                   RowBox[{"[", "k", "]"}], "]"}]}], "-", 
                 RowBox[{"repSites", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], ",", "L"}], "]"}], "+", 
              "1"}], "]"}], "]"}], "-", 
           RowBox[{"kernel", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"m", "*", 
                  RowBox[{"prime", "[", 
                   RowBox[{"[", "k", "]"}], "]"}]}], "-", 
                 RowBox[{"repSites", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], ",", "L"}], "]"}], "+", 
              "1"}], "]"}], "]"}]}], "\n", ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", 
            RowBox[{"Length", "[", "repSites", "]"}]}], "}"}], "\n", ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "2", ",", 
            RowBox[{
             RowBox[{"Length", "[", "repSites", "]"}], "+", "1"}]}], "}"}]}], 
         "]"}]}], ";", "\n", 
       RowBox[{"Return", "[", 
        RowBox[{"matrix", ",", "Module"}], "]"}]}]}], "\n", "]"}]}], ";"}], 
