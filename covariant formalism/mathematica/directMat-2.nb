c512c375f6ab"],

Cell[TextData[{
 "Taking the traced matrix directly using a pre-calculated LxL matrix, and \
adding up the four identified locations under the trace. i.e. one should ",
 StyleBox["first",
  FontWeight->"Bold"],
 " run DirectMat[L] or DirectMatN[L,NPrec] and store the result under some \
name, ",
 StyleBox["then ",
  FontWeight->"Bold"],
 "run DirectTracedMat[L, l1, l2, \[OpenCurlyDoubleQuote]matrix name\
\[CloseCurlyDoubleQuote]]"
}], "Text",
 CellChangeTimes->{{3.971272815927511*^9, 3.9712728282013493`*^9}, {
  3.971273131844221*^9, 3.971273205175617*^9}, {3.9713452553489323`*^9, 
  3.971345328038204*^9}},ExpressionUUID->"f8f1dae4-8e37-134c-9f57-\
04d336000ed9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Mat_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "l", ",", "i", ",", "j", ",", "tempMat", ",", "tempTracedMat", 
      ",", "segments", ",", "segmentMaps"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempTracedMat", "=", 
      RowBox[{"Mat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}], ",", 
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segments", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "l1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", 
          RowBox[{"l1", "+", "l2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segmentMaps", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", 
           RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "#1"}], ",", 
            "L", ",", "1"}], "]"}], ")"}], "&"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "go", " ", "over", " ", "the", " ", "9", " ", "blocks", " ", "of", 
         " ", "the", " ", "traced", " ", "matrix"}], ",", " ", 
        RowBox[{"labeled", " ", "by", " ", "i", " ", "j"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "go", " ", "over", " ", "all", " ", "the", " ", "entries", " ", 
           "in", " ", "the", " ", "i", " ", "j", " ", "block"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tempTracedMat", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"tempTracedMat", "[", 
              RowBox[{"[", 
               RowBox[{"k", ",", "l"}], "]"}], "]"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  "l"}], "]"}], "]"}], "+", 
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}], "+", 
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"k", ",", "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}]}],
               "}"}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempTracedMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.971272841182049*^9, 3.971272867739998*^9}, 
   3.971345304872539*^9, 3.971345388520544*^9},
 CellLabel->"In[30]:=",ExpressionUUID->"7f5aecf1-50ca-a54b-b096-05408d1627af"],

