Cell["\<\
\\<\\
Can generate the B matrix or B B^\\\\dagger matrix with roughly the same \
speed. \\
Then can take either Abs[Det[B]]^2 or Exp[logDetCholesky[BB^\\\\dagger]]. \
Make \\
sure to use Developer`ToPackedArray[...,Complex]\\
\\>\
\>", "Text",ExpressionUUID->"80803082-03ec-7f4f-b689-4d898a27c974"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BmatFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_", ",", 
     RowBox[{"NPrec_", " ", ":", " ", "prec"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "k1", ",", "k2", ",", "k3", ",", "kernel", ",", "prime", ",", 
       "matrix"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"prime", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], ")"}],
            ",", 
           RowBox[{"{", 
            RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", 
             RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k2", ",", 
             RowBox[{"l1", "+", "1"}], ",", 
             RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k3", ",", 
             RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
             RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", "\n", 
      RowBox[{"kernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{"2", "Pi", " ", "I", " ", 
              RowBox[{"n", "/", "L"}]}], ")"}]}], ",", "NPrec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "0", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"matrix", "=", 
       RowBox[{"Table", "[", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", "k"}], "-", "k"}], ",", "L"}], "]"}], "+", 
             "1"}], "]"}], "]"}], "-", 
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", 
                 RowBox[{"prime", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], "-", "k"}], ",", "L"}], 
              "]"}], "+", "1"}], "]"}], "]"}]}], "\n", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}], "\n", ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"Return", "[", 
       RowBox[{"matrix", ",", "Module"}], "]"}], ";"}]}], "\n", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"BdetFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
   RowBox[{"Det", "[", 
    RowBox[{"Developer`ToPackedArray", "[", 
     RowBox[{
      RowBox[{"BmatFast", "[", 
       RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "Complex"}], "]"}], 
    "]"}]}], ";"}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"6e5bf95d-5486-f04f-92c1-b093532c2b80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BBdaggermat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", 
    RowBox[{"Nprec_", ":", "prec"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "kernel", ",", "matrix", ",", "prime", ",", "k1", ",", "k2", ",", "k3"}],
      "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"kernel", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "4"}], "+", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "2", "*", "Pi", "*", 
               RowBox[{"n", "/", "L"}]}], "]"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "*", 
                  RowBox[{"n", "/", "2"}]}], "]"}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "*", 
                  RowBox[{"n", "/", "L"}]}], "]"}], ")"}]}], ")"}]}], ",", 
            "Nprec"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", 
            RowBox[{
             RowBox[{"-", "L"}], "+", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"L", "/", "2"}], "}"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "4"}], "+", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "2", "*", "Pi", "*", 
               RowBox[{"n", "/", "L"}]}], "]"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "*", 
                  RowBox[{"n", "/", "2"}]}], "]"}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"Sin", "[", 
                 RowBox[{"Pi", "*", 
                  RowBox[{"n", "/", "L"}]}], "]"}], ")"}]}], ")"}]}], ",", 
            "Nprec"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], "]"}]}], ";", "\n", 
     RowBox[{"prime", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], ")"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "/", "2"}], "+", 
            RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], ")"}], ",", 
          RowBox[{"{", 
           RowBox[{"k2", ",", 
            RowBox[{"l1", "+", "1"}], ",", 
            RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"k3", ",", 
            RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
            RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", "\n", 
     RowBox[{"matrix", "=", 
      RowBox[{"Table", "[", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", "l", "+", "L"}], "]"}], "]"}], "+", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"prime", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "-", 
            RowBox[{"prime", "[", 
             RowBox[{"[", "l", "]"}], "]"}], "+", "L"}], "]"}], "]"}], "-", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", 
            RowBox[{"prime", "[", 
             RowBox[{"[", "l", "]"}], "]"}], "+", "L"}], "]"}], "]"}], "-", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"prime", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "-", "l", "+", "L"}], "]"}], 
          "]"}]}], "\n", ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"L", "/", "2"}]}], "}"}], "\n", ",", 
        RowBox[{"{", 
         RowBox[{"l", ",", "1", ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"Return", "[", 
      RowBox[{"matrix", ",", "Module"}], "]"}], ";"}]}], "\n", 
   "]"}]}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"d3493985-1e74-ec49-a6b0-b6e74335b2fa"],

Cell["Can also do the same for B^(n) matrix", "Text",ExpressionUUID->"a7899125-7a98-9240-8b1e-d95be7143863"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BnmatFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "n_", ",", 
     RowBox[{"NPrec_", " ", ":", " ", "prec"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "k1", ",", "k2", ",", "k3", ",", "kernel", ",", "prime", ",", "matrix", 
       ",", "mList", ",", "m"}], "}"}], ",", "\n", 
     RowBox[{
      RowBox[{"prime", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], ")"}],
            ",", 
           RowBox[{"{", 
            RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", 
             RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k2", ",", 
             RowBox[{"l1", "+", "1"}], ",", 
             RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k3", ",", 
             RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
             RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", "\n", 
      RowBox[{"kernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{"2", "Pi", " ", "I", " ", 
              RowBox[{"m", "/", "L"}]}], ")"}]}], ",", "NPrec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "0", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"mList", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", "n", "}"}], ",", 
         RowBox[{"Range", "[", 
          RowBox[{"2", ",", 
           RowBox[{"L", "/", "2"}]}], "]"}]}], "]"}]}], ";", "\n", 
      RowBox[{"matrix", "=", 
       RowBox[{"Table", "[", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", "k"}], "-", "k"}], ",", "L"}], "]"}], "+", 
             "1"}], "]"}], "]"}], "-", 
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", 
                 RowBox[{"prime", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], "-", "k"}], ",", "L"}], 
              "]"}], "+", "1"}], "]"}], "]"}]}], "\n", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}], "\n", ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "mList"}], "}"}]}], "]"}]}], ";", "\n", 
      RowBox[{"Return", "[", 
       RowBox[{"matrix", ",", "Module"}], "]"}], ";"}]}], "\n", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"BndetFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"Det", "[", 
    RowBox[{"Developer`ToPackedArray", "[", 
     RowBox[{
      RowBox[{"BnmatFast", "[", 
       RowBox[{"L", ",", "l1", ",", "l2", ",", "n"}], "]"}], ",", "Complex"}],
      "]"}], "]"}]}], ";"}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"806a5031-4168-c94c-b7ef-5cb06de94e72"],

Cell["\<\
### Generalized one-face B matrix from full boundary word

For a generic one-face ribbon graph, the traced disc boundary is encoded by a \
cyclic boundary word in which each edge label appears exactly twice. The \
generalized helper below takes that full boundary word, together with edge \
lengths, and constructs the site-by-site `prime` map by pairing the first and \
second occurrence of each edge with opposite local orientation.

For genus 2, the boundary word has length `18` and the edge-length list has \
length `9`. A convenience wrapper also allows the last edge length to be \
inferred from `L/2-Total[first 8]`.\
\>", "Text",ExpressionUUID->"a5689fc2-c309-2a4f-95a4-25e13dc078e8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CompleteEdgeLengthsFromPartial", "[", 
     RowBox[{"L_", ",", "edgeLens_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"half", "=", 
         RowBox[{"Quotient", "[", 
          RowBox[{"L", ",", "2"}], "]"}]}], ",", 
        RowBox[{"lens", "=", "edgeLens"}], ",", "lastLen"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"OddQ", "[", "L", "]"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "lens", "]"}], "==", "8"}], ",", "\n", 
         RowBox[{
          RowBox[{"lastLen", "=", 
           RowBox[{"half", "-", 
            RowBox[{"Total", "[", "lens", "]"}]}]}], ";", "\n", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"lastLen", "<=", "0"}], ",", 
            RowBox[{"Return", "[", 
             RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
          RowBox[{"lens", "=", 
           RowBox[{"Join", "[", 
            RowBox[{"lens", ",", 
             RowBox[{"{", "lastLen", "}"}]}], "]"}]}]}]}], "\n", "]"}], ";", 
       "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Total", "[", "lens", "]"}], "=!=", "half"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"And", "@@", 
           RowBox[{"(", 
            RowBox[{"IntegerQ", "/@", "lens"}], ")"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"And", "@@", 
           RowBox[{"Thread", "[", 
            RowBox[{"lens", ">", "0"}], "]"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"Return", "[", 
        RowBox[{"lens", ",", "Module"}], "]"}]}]}], "\n", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"PrimeDataFromBoundaryWord", "[", 
     RowBox[{"L_", ",", "boundaryWord_List", ",", "edgeLens_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "lens", ",", "nEdges", ",", "segmentLens", ",", "starts", ",", 
        "firstPos", ",", "secondPos", ",", "repSegs", ",", "repSites", ",", 
        "prime"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"lens", "=", 
        RowBox[{"CompleteEdgeLengthsFromPartial", "[", 
         RowBox[{"L", ",", "edgeLens"}], "]"}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"lens", "===", "$Failed"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"nEdges", "=", 
        RowBox[{"Length", "[", "lens", "]"}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "boundaryWord", "]"}], "=!=", 
          RowBox[{"2", " ", "nEdges"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sort", "[", "boundaryWord", "]"}], "=!=", 
          RowBox[{"Sort", "@", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"Range", "[", "nEdges", "]"}], ",", 
             RowBox[{"Range", "[", "nEdges", "]"}]}], "]"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"segmentLens", "=", 
        RowBox[{"lens", "[", 
         RowBox[{"[", "boundaryWord", "]"}], "]"}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Total", "[", "segmentLens", "]"}], "=!=", "L"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"starts", "=", 
        RowBox[{"Most", "[", 
         RowBox[{"FoldList", "[", 
          RowBox[{"Plus", ",", "1", ",", "segmentLens"}], "]"}], "]"}]}], ";",
        "\n", 
       RowBox[{"firstPos", "=", 
        RowBox[{"Association", "[", "]"}]}], ";", "\n", 
       RowBox[{"secondPos", "=", 
        RowBox[{"Association", "[", "]"}]}], ";", "\n", 
       RowBox[{"Do", "[", "\n", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"KeyExistsQ", "[", 
            RowBox[{"firstPos", ",", 
             RowBox[{"boundaryWord", "[", 
              RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
           RowBox[{
            RowBox[{"secondPos", "[", 
             RowBox[{"boundaryWord", "[", 
              RowBox[{"[", "j", "]"}], "]"}], "]"}], "=", "j"}], ",", 
           RowBox[{
            RowBox[{"firstPos", "[", 
             RowBox[{"boundaryWord", "[", 
              RowBox[{"[", "j", "]"}], "]"}], "]"}], "=", "j"}]}], "]"}], 
         "\n", ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", 
           RowBox[{"2", " ", "nEdges"}]}], "}"}]}], "]"}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Sort", "[", 
            RowBox[{"Keys", "[", "firstPos", "]"}], "]"}], "=!=", 
           RowBox[{"Range", "[", "nEdges", "]"}]}], "||", 
          RowBox[{
           RowBox[{"Sort", "[", 
            RowBox[{"Keys", "[", "secondPos", "]"}], "]"}], "=!=", 
           RowBox[{"Range", "[", "nEdges", "]"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"repSegs", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Range", "[", "nEdges", "]"}], ",", 
          RowBox[{
           RowBox[{"firstPos", "[", "#", "]"}], "&"}]}], "]"}]}], ";", "\n", 
       RowBox[{"repSites", "=", 
        RowBox[{"Flatten", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{"starts", "[", 
              RowBox[{"[", 
               RowBox[{"firstPos", "[", "e", "]"}], "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"starts", "[", 
               RowBox[{"[", 
                RowBox[{"firstPos", "[", "e", "]"}], "]"}], "]"}], "+", 
              RowBox[{"lens", "[", 
               RowBox[{"[", "e", "]"}], "]"}], "-", "1"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"e", ",", "repSegs"}], "}"}]}], "]"}]}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "repSites", "]"}], "=!=", 
          RowBox[{"Quotient", "[", 
           RowBox[{"L", ",", "2"}], "]"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"prime", "=", 
        RowBox[{"Flatten", "@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Range", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"starts", "[", 
               RowBox[{"[", 
                RowBox[{"secondPos", "[", "e", "]"}], "]"}], "]"}], "+", 
              RowBox[{"lens", "[", 
               RowBox[{"[", "e", "]"}], "]"}], "-", "1"}], ",", 
             RowBox[{"starts", "[", 
              RowBox[{"[", 
               RowBox[{"secondPos", "[", "e", "]"}], "]"}], "]"}], ",", 
             RowBox[{"-", "1"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"e", ",", "repSegs"}], "}"}]}], "]"}]}]}], ";", "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "prime", "]"}], "=!=", 
          RowBox[{"Quotient", "[", 
           RowBox[{"L", ",", "2"}], "]"}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<EdgeLengths\>\"", "->", "lens"}], ",", 
         RowBox[{"\"\<SegmentLengths\>\"", "->", "segmentLens"}], ",", 
         RowBox[{"\"\<SegmentStarts\>\"", "->", "starts"}], ",", 
         RowBox[{"\"\<RepresentativeEdges\>\"", "->", "repSegs"}], ",", 
         RowBox[{"\"\<RepresentativeSites\>\"", "->", "repSites"}], ",", 
         RowBox[{"\"\<Prime\>\"", "->", "prime"}]}], "|>"}]}]}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BmatFastGeneralF1", "[", 
     RowBox[{"L_", ",", "boundaryWord_List", ",", "edgeLens_List", ",", 
      RowBox[{"NPrec_", ":", "prec"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "kernel", ",", "primeData", ",", "repSites", ",", "prime", ",", 
        "matrix"}], "}"}], ",", "\n", 
      RowBox[{
       RowBox[{"primeData", "=", 
        RowBox[{"PrimeDataFromBoundaryWord", "[", 
         RowBox[{"L", ",", "boundaryWord", ",", "edgeLens"}], "]"}]}], ";", 
       "\n", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"primeData", "===", "$Failed"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"$Failed", ",", "Module"}], "]"}]}], "]"}], ";", "\n", 
       RowBox[{"repSites", "=", 
        RowBox[{"primeData", "[", "\"\<RepresentativeSites\>\"", "]"}]}], ";",
        "\n", 
       RowBox[{"prime", "=", 
        RowBox[{"primeData", "[", "\"\<Prime\>\"", "]"}]}], ";", "\n", 
       RowBox[{"kernel", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{"E", "^", 
             RowBox[{"(", 
              RowBox[{"2", "Pi", " ", "I", " ", 
               RowBox[{"n", "/", "L"}]}], ")"}]}], ",", "NPrec"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "0", ",", 
            RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", "\n", 
       RowBox[{"matrix", "=", 
        RowBox[{"Table", "[", "\n", 
         RowBox[{
          RowBox[{
           RowBox[{"kernel", "[", 
