Cell["\<\
Generate the matrix directly without resorting to taking a sum and \
derivatives of that sum\
\>", "Text",
 CellChangeTimes->{{3.971265780394005*^9, 
  3.971265803484127*^9}},ExpressionUUID->"2acfa3bf-a136-604c-8f86-\
ad66e150b97d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectMat", "[", "L_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
          "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
           "]"}], "+", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{
            FractionBox[
             RowBox[{"-", 
              RowBox[{"Sin", "[", 
               FractionBox["\[Pi]", "L"], "]"}]}], 
             RowBox[{
              RowBox[{"Cos", "[", 
               FractionBox["\[Pi]", "L"], "]"}], "-", 
              RowBox[{"Cos", "[", 
               FractionBox[
                RowBox[{"2", " ", "k", " ", "\[Pi]"}], "L"], "]"}]}]], "/", 
            RowBox[{"(", " ", "L", ")"}]}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "+", 
          RowBox[{
           FractionBox["1", "2"], 
           RowBox[{
            FractionBox[
             RowBox[{"-", 
              RowBox[{"Sin", "[", 
               FractionBox["\[Pi]", "L"], "]"}]}], 
             RowBox[{
              RowBox[{"Cos", "[", 
               FractionBox["\[Pi]", "L"], "]"}], "-", 
              RowBox[{"Cos", "[", 
               FractionBox[
                RowBox[{"2", " ", "k", " ", "\[Pi]"}], "L"], "]"}]}]], "/", 
            RowBox[{"(", "L", ")"}]}]}]}]}], ";"}], "\[IndentingNewLine]", 
       ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.971259781929802*^9, 3.971259805960846*^9}, {
  3.971259837324028*^9, 3.971259880493242*^9}, {3.9712599122166023`*^9, 
  3.971259979466018*^9}, {3.971260066659193*^9, 3.9712601470134087`*^9}, {
