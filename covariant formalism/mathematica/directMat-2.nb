Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectRedDet", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Det", "[", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "prec"}], "]"}], 
    "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"L", "/", "2"}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DirectRedDetN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "NPrec_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Det", "[", 
    RowBox[{"DirectRedTracedMatN", "[", 
     RowBox[{"L", ",", "l1", ",", "l2", ",", "NPrec"}], "]"}], "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"L", "/", "2"}], ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logDetCholesky", "[", 
   RowBox[{"m_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "r", "}"}], ",", 
    RowBox[{
     RowBox[{"r", "=", 
      RowBox[{"CholeskyDecomposition", "[", "m", "]"}]}], ";", 
     RowBox[{"2", " ", 
      RowBox[{"Total", "[", 
       RowBox[{"Log", "[", 
        RowBox[{"Diagonal", "[", "r", "]"}], "]"}], "]"}]}]}]}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.971345845356189*^9, 3.97134593721281*^9}, {
