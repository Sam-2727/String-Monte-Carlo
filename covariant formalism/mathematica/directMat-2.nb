Cell["Reduced determinants", "Text",ExpressionUUID->"a5190ee3-9429-0a48-a352-9aa55ba017a6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectRedDet", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Det", "[", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "prec"}], "]"}], 
    "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"L", "/", "2"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"DirectRedDetN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "NPrec_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Det", "[", 
    RowBox[{"DirectRedTracedMatN", "[", 
     RowBox[{"L", ",", "l1", ",", "l2", ",", "NPrec"}], "]"}], "]"}], "/", 
   RowBox[{"(", 
    RowBox[{"L", "/", "2"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"logDetCholesky", "[", 
   RowBox[{"m_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "r", "}"}], ",", 
    RowBox[{
     RowBox[{"r", "=", 
