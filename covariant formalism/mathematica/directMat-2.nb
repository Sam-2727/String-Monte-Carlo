 CellLabel->"In[38]:=",ExpressionUUID->"36521e09-144c-f542-93a4-49833380f17d"],

Cell["\<\
Can generate the B matrix or B B^\\dagger matrix with roughly the same speed. \
Then can take either Abs[Det[B]]^2 or Exp[logDetCholesky[BB^\\dagger]]. Make \
sure to use Developer`ToPackedArray[...,Complex]\
\>", "Text",
 CellChangeTimes->{{3.9798139734710865`*^9, 3.97981398818944*^9}, {
  3.9798143988983994`*^9, 
  3.9798145140397415`*^9}},ExpressionUUID->"f1072276-c456-3a49-a06d-\
c1f3de86ea99"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BmatFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_", ",", 
     RowBox[{"NPrec_", " ", ":", " ", "prec"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "k1", ",", "k2", ",", "k3", ",", "kernel", ",", "prime", ",", 
       "matrix"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"prime", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], ")"}],
            ",", 
           RowBox[{"{", 
            RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"L", "/", "2"}], "+", 
             RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k2", ",", 
             RowBox[{"l1", "+", "1"}], ",", 
             RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
           ",", 
           RowBox[{"{", 
            RowBox[{"k3", ",", 
             RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
             RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"kernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"E", "^", 
            RowBox[{"(", 
             RowBox[{"2", "Pi", " ", "I", " ", 
              RowBox[{"n", "/", "L"}]}], ")"}]}], ",", "NPrec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "0", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"matrix", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", "k"}], "-", "k"}], ",", "L"}], "]"}], "+", 
             "1"}], "]"}], "]"}], "-", 
          RowBox[{"kernel", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "*", 
                 RowBox[{"prime", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}], "-", "k"}], ",", "L"}], 
              "]"}], "+", "1"}], "]"}], "]"}]}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"m", ",", "1", ",", 
           RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"matrix", ",", "Module"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"BdetFast", "[", 
    RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
   RowBox[{"Det", "[", 
    RowBox[{"Developer`ToPackedArray", "[", 
     RowBox[{
      RowBox[{"BmatFast", "[", 
       RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "Complex"}], "]"}], 
    "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.979814054946867*^9, 3.979814251769621*^9}, {
  3.980523835086157*^9, 3.980523837425751*^9}, {3.981551982939682*^9, 
  3.981551983144932*^9}},
 CellLabel->"In[50]:=",ExpressionUUID->"38a51f09-04ad-0542-b445-365e9ea772c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BBdaggermat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", 
    RowBox[{"Nprec_", ":", "prec"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "kernel", ",", "matrix", ",", "prime", ",", "k1", ",", "k2", ",", "k3"}],
      "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"kernel", " ", "=", " ", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "4"}], "+", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "2", "*", "Pi", "*", 
               RowBox[{"n", "/", "L"}]}], "]"}], 
             RowBox[{"(", 
              FractionBox[
               RowBox[{"Sin", "[", 
                RowBox[{"Pi", "*", 
                 RowBox[{"n", "/", "2"}]}], "]"}], 
               RowBox[{"Sin", "[", 
                RowBox[{"Pi", "*", 
                 RowBox[{"n", "/", "L"}]}], "]"}]], ")"}]}], ",", "Nprec"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", 
            RowBox[{
             RowBox[{"-", "L"}], "+", "1"}], ",", 
            RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"L", "/", "2"}], "}"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exp", "[", 
              RowBox[{"I", "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"L", "/", "4"}], "+", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "2", "*", "Pi", "*", 
               RowBox[{"n", "/", "L"}]}], "]"}], 
             RowBox[{"(", 
              FractionBox[
               RowBox[{"Sin", "[", 
                RowBox[{"Pi", "*", 
                 RowBox[{"n", "/", "2"}]}], "]"}], 
               RowBox[{"Sin", "[", 
                RowBox[{"Pi", "*", 
                 RowBox[{"n", "/", "L"}]}], "]"}]], ")"}]}], ",", "Nprec"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "1", ",", 
            RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"prime", "=", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k1"}], ")"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"k1", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"L", "/", "2"}], "+", 
            RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "k2"}], ")"}], ",", 
          RowBox[{"{", 
           RowBox[{"k2", ",", 
            RowBox[{"l1", "+", "1"}], ",", 
            RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k3"}], ")"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"k3", ",", 
            RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
            RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"matrix", "=", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", "l", "+", "L"}], "]"}], "]"}], "+", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"prime", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "-", 
            RowBox[{"prime", "[", 
             RowBox[{"[", "l", "]"}], "]"}], "+", "L"}], "]"}], "]"}], "-", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{"k", "-", 
            RowBox[{"prime", "[", 
             RowBox[{"[", "l", "]"}], "]"}], "+", "L"}], "]"}], "]"}], "-", 
         RowBox[{"kernel", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"prime", "[", 
             RowBox[{"[", "k", "]"}], "]"}], "-", "l", "+", "L"}], "]"}], 
          "]"}]}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"L", "/", "2"}]}], "}"}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"l", ",", "1", ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"matrix", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.979811208413641*^9, 3.979811349232481*^9}, 
   3.979811439171743*^9, {3.979811482294447*^9, 3.979811698479456*^9}, {
   3.9798117453628488`*^9, 3.979811785825379*^9}, {3.979811837593033*^9, 
   3.979811844084085*^9}, {3.9798121369441996`*^9, 3.979812268533142*^9}, {
   3.9798134889766808`*^9, 3.979813492463793*^9}, {3.979813797500063*^9, 
   3.9798137998412743`*^9}, {3.979813840684616*^9, 3.979813842765425*^9}, {
   3.9798140486447544`*^9, 3.979814050277939*^9}, {3.981551965242758*^9, 
   3.981551980159809*^9}},ExpressionUUID->"c95d3635-2b7a-ae48-9556-\
