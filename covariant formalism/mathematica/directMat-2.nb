     RowBox[{"2", " ", 
      RowBox[{"Total", "[", 
       RowBox[{"Log", "[", 
        RowBox[{"Diagonal", "[", "r", "]"}], "]"}], "]"}]}]}]}], 
   "]"}]}]}], "Input",
