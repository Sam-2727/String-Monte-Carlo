      RowBox[{
      "k1", ",", "k2", ",", "k3", ",", "kernel", ",", "prime", ",", "matrix", 
       ",", "mList", ",", "m"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"prime", "=", 
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
