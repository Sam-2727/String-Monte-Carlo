Notebook[{
Cell["prec=100;", "Text",ExpressionUUID->"eb97bc7f-899d-6742-97ea-816bee909739"],

Cell["\<\
\\<\\
Generate the matrix directly without resorting to taking a sum and \\
derivatives of that sum\\
\\>\
\>", "Text",ExpressionUUID->"50bb30e8-8998-424c-8eae-76e6537664c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectMat", "[", "L_", "]"}], ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
          "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
           "]"}], "+", 
          RowBox[{
           RowBox[{
            RowBox[{"(", "1", ")"}], "/", 
            RowBox[{"(", "2", ")"}]}], 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", 
               RowBox[{"Sin", "[", 
                RowBox[{
                 RowBox[{"(", "\[Pi]", ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{
                 RowBox[{"(", "\[Pi]", ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}], "-", 
               RowBox[{"Cos", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", " ", "k", " ", "\[Pi]"}], ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}]}], "/", 
            RowBox[{"(", " ", "L", ")"}]}]}]}]}], ";", "\n", 
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "+", 
          RowBox[{
           RowBox[{
            RowBox[{"(", "1", ")"}], "/", 
            RowBox[{"(", "2", ")"}]}], 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", 
               RowBox[{"Sin", "[", 
                RowBox[{
                 RowBox[{"(", "\[Pi]", ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{
                 RowBox[{"(", "\[Pi]", ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}], "-", 
               RowBox[{"Cos", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"2", " ", "k", " ", "\[Pi]"}], ")"}], "/", 
                 RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}]}], "/", 
            RowBox[{"(", "L", ")"}]}]}]}]}], ";"}], "\n", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", "\n", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], "\n", 
   "]"}]}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"05617964-03e8-644f-aa8d-0d8efe7f0bd7"],

Cell["\<\
\\<\\
Numerical version with precision Nprec, to avoid storing analytic expressions \
\\
of sines and cosines\\
\\>\
\>", "Text",ExpressionUUID->"7b377d9f-e5f1-884d-b11c-893fd5549754"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectMatN", "[", 
   RowBox[{"L_", ",", "NPrec_"}], "]"}], ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", "\n", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
          "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
           "]"}], "+", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", "1", ")"}], "/", 
              RowBox[{"(", "2", ")"}]}], 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"-", 
                 RowBox[{"Sin", "[", 
                  RowBox[{
                   RowBox[{"(", "\[Pi]", ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Cos", "[", 
                  RowBox[{
                   RowBox[{"(", "\[Pi]", ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}], "-", 
                 RowBox[{"Cos", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", " ", "k", " ", "\[Pi]"}], ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}]}], "/", 
              RowBox[{"(", " ", "L", ")"}]}]}], ",", "NPrec"}], "]"}]}]}], 
        ";", "\n", 
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "+", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", "1", ")"}], "/", 
              RowBox[{"(", "2", ")"}]}], 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"-", 
                 RowBox[{"Sin", "[", 
                  RowBox[{
                   RowBox[{"(", "\[Pi]", ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Cos", "[", 
                  RowBox[{
                   RowBox[{"(", "\[Pi]", ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}], "-", 
                 RowBox[{"Cos", "[", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{"2", " ", "k", " ", "\[Pi]"}], ")"}], "/", 
                   RowBox[{"(", "L", ")"}]}], "]"}]}], ")"}]}], "/", 
              RowBox[{"(", "L", ")"}]}]}], ",", "NPrec"}], "]"}]}]}], ";"}], 
       "\n", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", "\n", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], "\n", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"DirectMatNFast", "[", 
   RowBox[{"L_", ",", "prec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "kernel", "}"}], ",", 
    RowBox[{
     RowBox[{"kernel", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sin", "[", 
             RowBox[{"Pi", "/", "L"}], "]"}]}], "/", 
           RowBox[{"(", 
            RowBox[{"L", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{"Pi", "/", "L"}], "]"}], "-", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", " ", "Pi", " ", 
                 RowBox[{"d", "/", "L"}]}], "]"}]}], ")"}]}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "0", ",", 
            RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}], ",", "prec"}], "]"}]}],
      ";", "\n", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"kernel", "[", 
        RowBox[{"[", 
         RowBox[{"1", "+", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"j", "-", "i"}], ",", "L"}], "]"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "L"}], "}"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"922408fb-172a-3343-84bc-4a8fafeb01d5"],

Cell["\<\
Taking the traced matrix directly using a pre-calculated LxL matrix, and 
adding up the four identified locations under the trace. i.e. one should \
firstBold run DirectMat[L] or DirectMatN[L,NPrec] and store the result under \
some 
name, then Boldrun DirectTracedMat[L, l1, l2, [OpenCurlyDoubleQuote]matrix name
[CloseCurlyDoubleQuote]]\
\>", "Text",ExpressionUUID->"4da8a429-317d-9d48-a8cd-69004122761b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Mat_"}], "]"}], ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "l", ",", "i", ",", "j", ",", "tempMat", ",", "tempTracedMat", 
      ",", "segments", ",", "segmentMaps"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"tempTracedMat", "=", 
      RowBox[{"Mat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}], ",", 
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"segments", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "l1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "1"}], ",", 
          RowBox[{"l1", "+", "l2"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
          RowBox[{"L", "/", "2"}]}], "}"}]}], "}"}]}], ";", "\n", 
     RowBox[{"segmentMaps", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "/", "2"}], "+", 
           RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "#1"}], ")"}], 
         "&"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "#1"}], ",", 
            "L", ",", "1"}], "]"}], ")"}], "&"}]}], "}"}]}], ";", "\n", 
     RowBox[{"Do", "[", "\n", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "go", " ", "over", " ", "the", " ", "9", " ", "blocks", " ", "of", 
         " ", "the", " ", "traced", " ", "matrix"}], ",", " ", 
        RowBox[{"labeled", " ", "by", " ", "i", " ", "j"}]}], "*)"}], "\n", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", "\n", 
         RowBox[{"(*", 
          RowBox[{
          "go", " ", "over", " ", "all", " ", "the", " ", "entries", " ", 
           "in", " ", "the", " ", "i", " ", "j", " ", "block"}], "*)"}], "\n", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tempTracedMat", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"tempTracedMat", "[", 
              RowBox[{"[", 
               RowBox[{"k", ",", "l"}], "]"}], "]"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  "l"}], "]"}], "]"}], "+", 
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}], "+", 
               RowBox[{"Mat", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}]}], ")"}]}]}], ";"}], "\n", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"k", ",", "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}]}],
               "}"}], "]"}], ";"}], "*)"}], "\n", ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\n", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "3"}], "}"}]}], "]"}], ";", "\n", 
     RowBox[{"Return", "[", 
      RowBox[{"tempTracedMat", ",", "Module"}], "]"}], ";"}]}], "\n", 
   "]"}]}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"d09f8666-7354-ed49-b2d0-ad3c33d99fdf"],

Cell["\<\
\\<\\
If a matrix isn\[CloseCurlyQuote]t given, the function generates it and feeds \
\\
it into the above method\\
\\>\
\>", "Text",ExpressionUUID->"9b84cf2e-afa8-3b4e-a89a-1bda51437178"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", "\n", 
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L", ",", "l1", ",", "l2", ",", 
    RowBox[{"DirectMat", "[", "L", "]"}]}], "]"}]}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"4d952f00-5a52-fb4c-ace6-98791efd5bb6"],

Cell["Same algorithm but using the numerical LxL matrix", "Text",ExpressionUUID->"ee7e5148-112d-8c4c-932b-ea0c7e9f7e23"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedMatN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "NPrec_"}], "]"}], ":=", "\n", 
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L", ",", "l1", ",", "l2", ",", 
    RowBox[{"DirectMatNFast", "[", 
     RowBox[{"L", ",", "NPrec"}], "]"}]}], "]"}]}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"759673fc-e7d5-8e4d-95ac-d80aa4bdfbc2"],

Cell["\<\
\\<\\
Taking the det after deleting the last row and column, (and numerical \\
version, and version with pre-calculated LxL matrix)\\
\\>\
\>", "Text",ExpressionUUID->"9c97b0e8-61b0-4347-b739-3e71187c003d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectDetPrime", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
  RowBox[{"Times", " ", "@@", " ", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"DirectTracedMat", "[", 
          RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "prec"}], "]"}], "//",
        "Eigenvalues"}], "//", "Chop"}], ",", "0"}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{"DirectDetPrimeN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Nprec_"}], "]"}], ":=", 
  RowBox[{"Times", " ", "@@", " ", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"DirectTracedMatN", "[", 
        RowBox[{"L", ",", "l1", ",", "l2", ",", "prec"}], "]"}], "//", 
       "Eigenvalues"}], "//", "Chop"}], ",", "0"}], "]"}]}]}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"dc80a5bd-4c5e-ae48-84bd-34a158885ed4"],

Cell["\<\
Taking the reduced traced matrix directly by starting with the a 
pre-calculated full LxL matrix above, first calculating the (L/2)th row and 
column, and adding up the four identified locations under the trace as well 
as the appropriate term from the (L/2)th row and column for the reduced 
traced matrix. i.e. one should firstBold run DirectMatN[L, NPrec] or \
DirectMat[L] and store the result under some 
name, then Boldrun DirectTracedMat[L, l1, l2, [OpenCurlyDoubleQuote]matrix name
[CloseCurlyDoubleQuote]]\
\>", "Text",ExpressionUUID->"09bcbda9-c874-7e4a-b91f-8e7c60a9b434"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectRedTracedMat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Mat_"}], "]"}], ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "l", ",", "i", ",", "j", ",", "tempMat", ",", "tempTracedMat", 
      ",", "segments", ",", "segmentMaps", ",", " ", "segmentFlag"}], "}"}], 
    ",", "\n", 
    RowBox[{
     RowBox[{"tempMat", "=", "Mat"}], ";", "\n", 
     RowBox[{"tempTracedMat", "=", 
      RowBox[{"tempMat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}], ",", 
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}]}], "]"}], "]"}]}], ";", "\n", 
     RowBox[{"segmentFlag", " ", "=", "\n", 
