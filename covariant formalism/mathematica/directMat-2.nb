   3.9713439196493263`*^9, 3.971343919919193*^9}, {3.9713440302676334`*^9, 
   3.971344045696593*^9}, {3.971344416153919*^9, 3.971344459873516*^9}, 
   3.971344775517794*^9, {3.971345100687113*^9, 3.971345107309824*^9}, {
   3.971345354471571*^9, 3.97134537848715*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"8a114c8c-0f13-1b4d-9a5e-04e640fdc1db"],

Cell["Same algorithm but using the numerical LxL matrix", "Text",
 CellChangeTimes->{{3.9712659001914787`*^9, 
  3.971265917183687*^9}},ExpressionUUID->"e9631d24-05e9-a646-b7af-\
a18801ff5e41"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectTracedMatN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "NPrec_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"DirectTracedMat", "[", 
   RowBox[{"L", ",", "l1", ",", "l2", ",", 
    RowBox[{"DirectMatNFast", "[", 
     RowBox[{"L", ",", "NPrec"}], "]"}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.971265595412844*^9, 3.97126561263627*^9}, {
  3.971345415625337*^9, 3.9713454200423374`*^9}, {3.9798058777467117`*^9, 
  3.979805878300455*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"1a8b1efb-9d84-7c4c-9087-5f010d79849d"],

Cell["\<\
Taking the det after deleting the last row and column, (and numerical \
version, and version with pre-calculated LxL matrix)\
\>", "Text",
 CellChangeTimes->{{3.971266363084285*^9, 3.971266376099821*^9}, {
  3.971266529369276*^9, 3.971266533513111*^9}, {3.971274307523508*^9, 
  3.97127433925968*^9}, {3.971340848918295*^9, 
  3.9713408495733643`*^9}},ExpressionUUID->"99e7b813-b016-2f4c-89da-\
7fa2e7c0b807"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectDetPrime", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
  RowBox[{"Times", " ", "@@", " ", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"DirectTracedMat", "[", 
          RowBox[{"L", ",", "l1", ",", "l2"}], "]"}], ",", "prec"}], "]"}], "//",
        "Eigenvalues"}], "//", "Chop"}], ",", "0"}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DirectDetPrimeN", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Nprec_"}], "]"}], ":=", 
  RowBox[{"Times", " ", "@@", " ", 
   RowBox[{"DeleteCases", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"DirectTracedMatN", "[", 
        RowBox[{"L", ",", "l1", ",", "l2", ",", "prec"}], "]"}], "//", 
       "Eigenvalues"}], "//", "Chop"}], ",", "0"}], "]"}]}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9712663788295193`*^9, 3.971266482679367*^9}, {
   3.971272885095329*^9, 3.971272892763025*^9}, 3.971340878268823*^9, {
   3.971345430491752*^9, 3.971345498828861*^9}, {3.971345565951027*^9, 
   3.971345583168913*^9}, 3.971346001327503*^9, {3.9713461021933975`*^9, 
   3.971346102896204*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"e53ae7d3-aa50-f144-9a26-4a9ada21b2b8"],

Cell[TextData[{
 "Taking the reduced traced matrix directly by starting with the a \
pre-calculated full LxL matrix above, first calculating the (L/2)th row and \
column, and adding up the four identified locations under the trace as well \
as the appropriate term from the (L/2)th row and column for the reduced \
traced matrix. i.e. one should ",
 StyleBox["first",
  FontWeight->"Bold"],
 " run DirectMatN[L, NPrec] or DirectMat[L] and store the result under some \
name, ",
 StyleBox["then ",
  FontWeight->"Bold"],
 "run DirectTracedMat[L, l1, l2, \[OpenCurlyDoubleQuote]matrix name\
\[CloseCurlyDoubleQuote]]"
}], "Text",
 CellChangeTimes->{{3.971265856354006*^9, 3.971265895324421*^9}, {
  3.971340885522974*^9, 3.9713409407772713`*^9}, {3.9713455965100727`*^9, 
  3.971345600032255*^9}, {3.9713457869414616`*^9, 
  3.971345800245409*^9}},ExpressionUUID->"b863e3fa-5c2c-ea45-b3ba-\
ebfb3d42ba53"],

Cell[BoxData[""], "Input",ExpressionUUID->"d1cf91e8-00f9-4e43-acc6-96807951b639"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectRedTracedMat", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "Mat_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "k", ",", "l", ",", "i", ",", "j", ",", "tempMat", ",", "tempTracedMat", 
      ",", "segments", ",", "segmentMaps", ",", " ", "segmentFlag"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", "Mat"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tempTracedMat", "=", 
      RowBox[{"tempMat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}], ",", 
         RowBox[{"1", ";;", 
          RowBox[{"L", "/", "2"}]}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"segmentFlag", " ", "=", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"l1", "+", "l2"}], "==", 
         RowBox[{"L", "/", "2"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"L", "/", "2"}], " ", "is", " ", "actually", " ", "in", " ",
           "the", " ", "second", " ", "segment", " ", "in", " ", "this", " ", 
          "case"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"segments", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "l1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2", "-", "1"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
              RowBox[{"L", "/", "2"}]}], "}"}]}], "}"}]}], ";", " ", 
         RowBox[{"(*", 
          RowBox[{
          "NOTE", " ", "second", " ", "segment", " ", "ends", " ", "early", 
           " ", "and", " ", "third", " ", "segment", " ", "is", " ", "now", 
           " ", "empty"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"segmentMaps", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "#1"}], 
              ")"}], "&"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"L", "/", "2"}], "+", 
               RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "#1"}], ")"}], 
             "&"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "#1"}], ",",
                 "L", ",", "1"}], "]"}], ")"}], "&"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", "2"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"segments", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "l1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", 
              RowBox[{
               RowBox[{"L", "/", "2"}], "-", "1"}]}], "}"}]}], "}"}]}], ";", 
         " ", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
           "NOTE", " ", "this", " ", "segment", " ", "now", " ", "ends", " ", 
            "at", " ", 
            RowBox[{"L", "/", "2"}]}], "-", 
           RowBox[{"1", " ", "because", " ", "we", " ", "do", " ", 
            RowBox[{"L", "/", "2"}], " ", "separately"}]}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"segmentMaps", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "#1"}], 
              ")"}], "&"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"L", "/", "2"}], "+", 
               RowBox[{"2", "l1"}], "+", "l2", "+", "1", "-", "#1"}], ")"}], 
             "&"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Mod", "[", 
               RowBox[{
                RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "#1"}], ",",
                 "L", ",", "1"}], "]"}], ")"}], "&"}]}], "}"}]}], ";", 
         "\[IndentingNewLine]", "3"}]}], "\[IndentingNewLine]", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"The", " ", 
        RowBox[{"L", "/", "2"}], "th", " ", "row"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tempTracedMat", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", 
               RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"tempTracedMat", "[", 
              RowBox[{"[", 
               RowBox[{"k", ",", 
                RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
                   RowBox[{"L", "/", "2"}], "]"}]}], "]"}], "]"}], "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
                   RowBox[{"L", "/", "2"}], "]"}]}], "]"}], "]"}]}], 
              ")"}]}]}], ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "segmentFlag"}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"The", " ", 
        RowBox[{"L", "/", "2"}], "th", " ", "column"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tempTracedMat", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"L", "/", "2"}], ",", "l"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"tempTracedMat", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"L", "/", "2"}], ",", "l"}], "]"}], "]"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
                   RowBox[{"L", "/", "2"}], "]"}], ",", "l"}], "]"}], "]"}], 
               "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
                   RowBox[{"L", "/", "2"}], "]"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}], "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"L", "/", "2"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "segmentFlag"}], "}"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"the", " ", 
        RowBox[{"L", "/", "2"}]}], ",", " ", 
       RowBox[{
        RowBox[{"L", "/", "2"}], " ", "corner"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tempTracedMat", "[", 
       RowBox[{"[", 
        RowBox[{
         RowBox[{"L", "/", "2"}], ",", 
         RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "=", 
      RowBox[{
       RowBox[{"tempTracedMat", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"L", "/", "2"}], ",", 
          RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "+", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"segmentMaps", "[", 
              RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
             RowBox[{"L", "/", "2"}], "]"}], ",", 
            RowBox[{"L", "/", "2"}]}], "]"}], "]"}], "+", 
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"segmentMaps", "[", 
              RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
             RowBox[{"L", "/", "2"}], "]"}], ",", 
            RowBox[{
             RowBox[{"segmentMaps", "[", 
              RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
             RowBox[{"L", "/", "2"}], "]"}]}], "]"}], "]"}], "+", 
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"L", "/", "2"}], ",", 
            RowBox[{
             RowBox[{"segmentMaps", "[", 
              RowBox[{"[", "segmentFlag", "]"}], "]"}], "[", 
             RowBox[{"L", "/", "2"}], "]"}]}], "]"}], "]"}]}], ")"}]}]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"go", " ", "over", " ", "the", " ", "9", " ", 
         RowBox[{"(", 
          RowBox[{"or", " ", "4"}], ")"}], " ", "blocks", " ", "of", " ", 
         "the", " ", "traced", " ", "matrix"}], ",", " ", 
        RowBox[{"labeled", " ", "by", " ", "i", " ", "j"}], ",", " ", 
        RowBox[{
         RowBox[{"now", " ", "going", " ", "up", " ", "to", " ", 
          RowBox[{"L", "/", "2"}]}], "-", "1"}]}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "go", " ", "over", " ", "all", " ", "the", " ", "entries", " ", 
           "in", " ", "the", " ", "i", " ", "j", " ", "block"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "add", " ", "the", " ", "extra", " ", "terms", " ", "from", " ", 
           "the", " ", 
           RowBox[{"(", 
            RowBox[{"L", "/", "2"}], ")"}], "th", " ", "row", " ", "and", " ",
            "column"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"tempTracedMat", "[", 
             RowBox[{"[", 
              RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"tempTracedMat", "[", 
              RowBox[{"[", 
               RowBox[{"k", ",", "l"}], "]"}], "]"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  "l"}], "]"}], "]"}], "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}], "+", 
               RowBox[{"tempMat", "[", 
                RowBox[{"[", 
                 RowBox[{"k", ",", 
                  RowBox[{
                   RowBox[{"segmentMaps", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "]"}], 
                "]"}]}], ")"}], "+", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"tempTracedMat", "[", 
                 RowBox[{"[", 
                  RowBox[{"k", ",", 
                   RowBox[{"L", "/", "2"}]}], "]"}], "]"}]}], "-", 
               RowBox[{"tempTracedMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"L", "/", "2"}], ",", "l"}], "]"}], "]"}], "+", 
               RowBox[{"tempTracedMat", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"L", "/", "2"}], ",", 
                  RowBox[{"L", "/", "2"}]}], "]"}], "]"}]}], ")"}]}]}], ";"}],
           "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"k", ",", "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 "l"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "i", "]"}], "]"}], "[", "k", "]"}], ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"k", ",", 
                 RowBox[{
                  RowBox[{"segmentMaps", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "[", "l", "]"}]}], "}"}]}],
               "}"}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"l", ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"segments", "[", 
             RowBox[{"[", 
              RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "segmentFlag"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "segmentFlag"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{
       RowBox[{"tempTracedMat", "[", 
        RowBox[{"[", 
         RowBox[{
