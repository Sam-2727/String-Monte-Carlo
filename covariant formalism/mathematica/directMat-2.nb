Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"table", ",", "tableSubset", ",", "fit", ",", "P1", ",", "P2"}], 
    "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"table", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"elt", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"Log", "[", 
          RowBox[{"elt", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"elt", ",", "TestTable3"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"tableSubset", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"table", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ">", "2000"}], "&"}]}], "]"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"P1", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{"table", ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"fit", "=", 
     RowBox[{"FindFit", "[", 
      RowBox[{"tableSubset", ",", 
       RowBox[{"b", "+", 
        RowBox[{"c", "*", 
         RowBox[{"Log", "[", "L", "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"b", ",", "c"}], "}"}], ",", "L"}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"P2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"b", "+", 
         RowBox[{"c", "*", 
          RowBox[{"Log", "[", "L", "]"}]}]}], "/.", "fit"}], ",", 
       RowBox[{"{", 
        RowBox[{"L", ",", "0", ",", "5400"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
