 CellLabel->"In[45]:=",ExpressionUUID->"56c314f8-d8ad-c74c-9e74-b24c33257656"],

Cell["\<\
Numerical version with precision Nprec, to avoid storing analytic expressions \
of sines and cosines\
\>", "Text",
 CellChangeTimes->{{3.971265809013363*^9, 
  3.9712658330744457`*^9}},ExpressionUUID->"84f7ad27-5219-bb4a-bfde-\
27ff2a74b4c4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectMatN", "[", 
   RowBox[{"L_", ",", "NPrec_"}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
          "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}]}], "]"}], 
           "]"}], "+", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             FractionBox["1", "2"], 
             RowBox[{
              FractionBox[
               RowBox[{"-", 
                RowBox[{"Sin", "[", 
                 FractionBox["\[Pi]", "L"], "]"}]}], 
               RowBox[{
                RowBox[{"Cos", "[", 
                 FractionBox["\[Pi]", "L"], "]"}], "-", 
                RowBox[{"Cos", "[", 
                 FractionBox[
                  RowBox[{"2", " ", "k", " ", "\[Pi]"}], "L"], "]"}]}]], "/", 
              RowBox[{"(", " ", "L", ")"}]}]}], ",", "NPrec"}], "]"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
            RowBox[{"Mod", "[", 
             RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"tempMat", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"Mod", "[", 
              RowBox[{
               RowBox[{"n", "+", "k"}], ",", "L", ",", "1"}], "]"}], ",", 
             RowBox[{"Mod", "[", 
              RowBox[{"n", ",", "L", ",", "1"}], "]"}]}], "]"}], "]"}], "+", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             FractionBox["1", "2"], 
             RowBox[{
              FractionBox[
               RowBox[{"-", 
                RowBox[{"Sin", "[", 
                 FractionBox["\[Pi]", "L"], "]"}]}], 
               RowBox[{
                RowBox[{"Cos", "[", 
                 FractionBox["\[Pi]", "L"], "]"}], "-", 
                RowBox[{"Cos", "[", 
                 FractionBox[
                  RowBox[{"2", " ", "k", " ", "\[Pi]"}], "L"], "]"}]}]], "/", 
              RowBox[{"(", "L", ")"}]}]}], ",", "NPrec"}], "]"}]}]}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DirectMatNFast", "[", 
   RowBox[{"L_", ",", "prec_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "kernel", "}"}], ",", 
    RowBox[{
     RowBox[{"kernel", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Sin", "[", 
             RowBox[{"Pi", "/", "L"}], "]"}]}], "/", 
           RowBox[{"(", 
            RowBox[{"L", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Cos", "[", 
                RowBox[{"Pi", "/", "L"}], "]"}], "-", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", " ", "Pi", " ", 
                 RowBox[{"d", "/", "L"}]}], "]"}]}], ")"}]}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"d", ",", "0", ",", 
            RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}], ",", "prec"}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"kernel", "[", 
        RowBox[{"[", 
         RowBox[{"1", "+", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"j", "-", "i"}], ",", "L"}], "]"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "L"}], "}"}]}], "]"}]}]}], 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.9712655552549934`*^9, 3.971265582788959*^9}, {
  3.971267384096828*^9, 3.9712673855628567`*^9}, {3.9713457439437943`*^9, 
  3.9713457493545933`*^9}, {3.9720340359185534`*^9, 3.972034036151544*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"ff2d3255-94c4-a244-a6d8-6c6afbdf068e"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.971867930421508*^9, 3.971867932649311*^9}, {
   3.971868031053997*^9, 3.9718680332563477`*^9}, {3.971868071078573*^9, 
