Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["fHatS", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "0", "]"}], 
      RowBox[{"12", " ", "\[Pi]", " ", 
       RowBox[{"fHatS", "[", "0", "]"}]}]]}], "+", 
    RowBox[{
     FractionBox["1", "6"], " ", 
     SuperscriptBox[
      RowBox[{"fHatS", "[", "0", "]"}], "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       FractionBox["3", 
        RowBox[{"Im", "[", "\[Tau]", "]"}]], "+", 
       FractionBox[
        RowBox[{"\[Pi]", " ", 
         RowBox[{
          SuperscriptBox["EllipticThetaPrime", 
           TagBox[
            RowBox[{"(", 
             RowBox[{"0", ",", "2", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"1", ",", "0", ",", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"\[ImaginaryI]", " ", "\[Pi]", " ", "\[Tau]"}]]}], 
          "]"}]}], 
        RowBox[{"EllipticThetaPrime", "[", 
         RowBox[{"1", ",", "0", ",", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"\[ImaginaryI]", " ", "\[Pi]", " ", "\[Tau]"}]]}], 
         "]"}]]}], ")"}]}]}], ",", "0", ",", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"120", " ", "\[Pi]", " ", 
      SuperscriptBox[
       RowBox[{"fHatS", "[", "0", "]"}], "2"]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"10", " ", 
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["fHatS", "\[Prime]\[Prime]",
          MultilineFunction->None], "[", "0", "]"}], "2"]}], "-", 
      RowBox[{"3", " ", 
       RowBox[{"fHatS", "[", "0", "]"}], " ", 
       RowBox[{
        SuperscriptBox["fHatS", 
         TagBox[
          RowBox[{"(", "4", ")"}],
          Derivative],
         MultilineFunction->None], "[", "0", "]"}]}], "+", 
      RowBox[{"20", " ", "\[Pi]", " ", 
       SuperscriptBox[
        RowBox[{"fHatS", "[", "0", "]"}], "3"], " ", 
       RowBox[{
        SuperscriptBox["fHatS", "\[Prime]\[Prime]",
         MultilineFunction->None], "[", "0", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         FractionBox["3", 
          RowBox[{"Im", "[", "\[Tau]", "]"}]], "+", 
         FractionBox[
          RowBox[{"\[Pi]", " ", 
           RowBox[{
            SuperscriptBox["EllipticThetaPrime", 
             TagBox[
              RowBox[{"(", 
               RowBox[{"0", ",", "2", ",", "0"}], ")"}],
              Derivative],
