Cell[BoxData[{
 RowBox[{
  RowBox[{"DirectCMat", "[", 
   RowBox[{"L_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"DirectFMat", "[", 
   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "m", "]"}], "!"}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "n", "]"}], "!"}], ")"}]}], 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "*", "#2"}], "+", 
            RowBox[{"n", "*", "#3"}]}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DirectCMatN", "[", 
   RowBox[{"L_", ",", "m_", ",", "n_", ",", "NPrec_"}], "]"}], ":=", 
  RowBox[{"DirectFMatN", "[", 
   RowBox[{"L", ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "m", "]"}], "!"}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Abs", "[", "n", "]"}], "!"}], ")"}]}], 
        SuperscriptBox["#1", "2"]], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], "*", "2", "*", "Pi", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "*", "#2"}], "+", 
            RowBox[{"n", "*", "#3"}]}], ")"}], "/", "#1"}]}], "]"}]}], ")"}], 
     "&"}], ",", "NPrec"}], "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008457784712*^9, 3.978008532203291*^9}, 
   3.978370019056921*^9, {3.9785301861958847`*^9, 3.9785301875362415`*^9}, {
