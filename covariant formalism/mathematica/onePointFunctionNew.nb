  RowBox[{"AMat", "=", 
   RowBox[{"DirectMatN", "[", 
    RowBox[{"setL", ",", "prec"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.977413340410406*^9, 3.9774134467267895`*^9}, {
