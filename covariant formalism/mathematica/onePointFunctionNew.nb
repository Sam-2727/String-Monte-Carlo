Cell["\<\
Given some function f_L[k,l] generate the corresponding matrix\
\>", "Text",
 CellChangeTimes->{{3.978008104572199*^9, 3.9780081423182716`*^9}, 
   3.978008183200157*^9, {3.9787256696717463`*^9, 
