          RowBox[{"[", "1", "]"}], "]"}]}], " ", 
        RowBox[{"is", " ", "\\", "hat"}], 
        RowBox[{"{", "f", "}"}], 
        RowBox[{"(", "0", ")"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
