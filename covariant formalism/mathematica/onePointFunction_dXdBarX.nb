Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"SAME", " ", "exact", " ", 
     RowBox[{"{", 
      RowBox[{"l1", ",", "l2", ",", "l3"}], "}"}], " ", "as", " ", "above", " ",
      "but", " ", "in", " ", "a", " ", "different", " ", "order"}], ",", " ", 
    RowBox[{
     RowBox[{"so", " ", "\[Tau]", " ", "will", " ", "be", " ", "different", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"related", " ", "by", " ", "modular", " ", "transformation"}],
         ")"}], ".", " ", "\[IndentingNewLine]", "Note"}], " ", "that", " ", 
      "tr", 
