Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "\[Pi]"], "-", 
      FractionBox[
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"fHatS", "[", "0", "]"}], "]"}], " ", 
        RowBox[{"fHatS", "[", "0", "]"}]}], 
       RowBox[{"Im", "[", "\[Tau]", "]"}]]}], ")"}]}], ",", "0", ",", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"fHatS", "[", "0", "]"}], "]"}], " ", 
      RowBox[{
       SuperscriptBox["fHatS", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "0", "]"}]}], 
     RowBox[{"2", " ", 
      RowBox[{"Im", "[", "\[Tau]", "]"}]}]]}], ",", "0", ",", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"fHatS", "[", "0", "]"}], "]"}], " ", 
      RowBox[{
       SuperscriptBox["fHatS", 
        TagBox[
         RowBox[{"(", "4", ")"}],
         Derivative],
        MultilineFunction->None], "[", "0", "]"}]}], 
     RowBox[{"2", " ", 
      RowBox[{"Im", "[", "\[Tau]", "]"}]}]]}]}], "}"}]], "Output",
