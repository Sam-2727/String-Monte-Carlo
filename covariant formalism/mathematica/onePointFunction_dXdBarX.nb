Cell[TextData[{
 "FindTrCA has the input (L,l1,l2) as usual.  s is an integer indicating that \
it is computing ",
 Cell[BoxData[
  FormBox[
   RowBox[{":", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[PartialD]", "s"], "X"}], " ", 
     RowBox[{
      OverscriptBox["\[PartialD]", "_"], "X"}]}], ":"}], TraditionalForm]],
  ExpressionUUID->"c4f7b941-71c3-4ed0-a28b-e35c2598a694"],
 "  on the disk.  \nOne has to input the correct CMat for ",
 Cell[BoxData[
  FormBox[
   RowBox[{":", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[PartialD]", "s"], "X"}], " ", 
     RowBox[{
      OverscriptBox["\[PartialD]", "_"], "X"}]}], ":"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "7a7ffb73-2d82-4b34-909f-20dcce67427d"],
 "  to get the correct matching.\nThe output is {\[Tau], Analytic result for \
one point function, numerical result for one-point function}"
}], "Text",
 CellChangeTimes->{{3.97872581660119*^9, 3.9787259690374928`*^9}, {
  3.9787260166728373`*^9, 3.978726157137445*^9}, {3.978790342579453*^9, 
  3.9787903524380617`*^9}},ExpressionUUID->"4ffd3e32-e857-43b3-852a-\
6182591ea498"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"findTrCA", "[", 
    RowBox[{
    "L_", ",", "l1_", ",", "l2_", ",", "s_", ",", "AMat_", ",", "CMat_"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "l3", ",", "redA", ",", "invA", ",", "redC", ",", "tr", ",", "f", ",", 
       "DerList", ",", "fHat", ",", "f0", ",", "df", ",", "ddf", ",", "per", ",",
        "perRed", ",", "AnalyticTest", ",", "NumericalTest", ",", "Formula", ",",
        "ReplaceTable"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"l3", "=", 
       RowBox[{
        RowBox[{"L", "/", "2"}], "-", "l1", "-", "l2"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "1", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"redA", "=", 
       RowBox[{"DirectRedTracedMat", "[", 
        RowBox[{"L", ",", "l1", ",", "l2", ",", "AMat"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "1", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"redC", "=", 
       RowBox[{"DirectRedTracedMat", "[", 
        RowBox[{"L", ",", "l1", ",", "l2", ",", "CMat"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "2", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"invA", "=", 
       RowBox[{"Inverse", "[", "redA", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Print", "[", "3", "]"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"f", "=", 
       RowBox[{"CylEqnFastOptimized", "[", 
        RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Print", "[", "4", "]"}], ";"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"NumericalTest", "=", 
       RowBox[{"Tr", "[", 
        RowBox[{"redC", " ", ".", " ", "invA"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"per", "=", 
       RowBox[{
        RowBox[{"PeriodsFastGivenF", "[", 
         RowBox[{"l1", ",", "l2", ",", "l3", ",", 
          RowBox[{"l1", "/", "2"}], ",", 
          RowBox[{"l2", "/", "2"}], ",", 
          RowBox[{"l3", "/", "2"}], ",", "f", ",", "z"}], "]"}], "//", 
        "N"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"perRed", "=", 
       RowBox[{"per", "/", 
        RowBox[{"per", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"fHat", "=", 
