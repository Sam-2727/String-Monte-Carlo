Cell["\<\
Given some function f_L[k,l] generate the corresponding matrix\
\>", "Text",
 CellChangeTimes->{{3.978008104572199*^9, 3.9780081423182716`*^9}, 
   3.978008183200157*^9, {3.9787256696717463`*^9, 
   3.978725673399706*^9}},ExpressionUUID->"39c87231-2f43-8d45-8c8d-\
270e5218924a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectFMat", "[", 
   RowBox[{"L_", ",", "f_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
         RowBox[{"f", "[", 
          RowBox[{"L", ",", "k", ",", "l"}], "]"}]}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008145795967*^9, 3.9780081875044513`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"16ba3481-ba77-e446-8219-5935d22def9d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DirectFMatN", "[", 
   RowBox[{"L_", ",", "f_", ",", "NPrec_"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"k", ",", "n", ",", "l", ",", "tempMat"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tempMat", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"L", ",", "L"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"tempMat", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "l"}], "]"}], "]"}], "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"f", "[", 
            RowBox[{"L", ",", "k", ",", "l"}], "]"}], ",", "NPrec"}], "]"}]}],
         ";"}], "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"l", ",", "1", ",", "L"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"tempMat", ",", "Module"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.978008199087793*^9, 3.978008212656801*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"a7aa48f4-b40e-ba4f-b9c9-13141227c67d"],

