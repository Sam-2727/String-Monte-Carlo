      RowBox[{"\\", "hat"}], 
      RowBox[{"{", "f", "}"}], 
      RowBox[{"(", "0", ")"}]}], "|", 
     RowBox[{
      RowBox[{"^", "2"}], " ", "is", " ", "not"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"L2", "=", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Print", "[", "k", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"findTrCA", "[", 
       RowBox[{"setL", ",", 
        RowBox[{
         RowBox[{"setL", "/", "2"}], "-", 
         RowBox[{"2", "k"}]}], ",", "k", ",", "AMat", ",", "CMat"}], "]"}]}], 
     "\[IndentingNewLine]", ",", 
