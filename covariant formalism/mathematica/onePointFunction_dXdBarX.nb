Cell["\<\
Compute the disk one point function by the conformal transformation of one \
point function on the torus\
\>", "Text",
 CellChangeTimes->{{3.978725717241413*^9, 
  3.978725751746519*^9}},ExpressionUUID->"a7ce1798-2d7b-4ebe-b795-\
693cf8e3f756"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Ord", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"u", "[", "z_", "]"}], ":=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"fHatS", "[", "a", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"a", ",", "0", ",", "z"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"uTrun", "[", "z_", "]"}], ":=", 
  RowBox[{"Series", "[", 
   RowBox[{
    RowBox[{"u", "[", "z", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"z", ",", "0", ",", 
      RowBox[{"Ord", "+", "3"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T2", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     RowBox[{"Series", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"fHatS", "[", "z", "]"}], 
         RowBox[{"Conjugate", "[", 
          RowBox[{"fHatS", "[", "0", "]"}], "]"}], " ", 
         RowBox[{"(", 
          FractionBox[
           RowBox[{"-", "1"}], 
           RowBox[{"2", 
            RowBox[{"Im", "[", "\[Tau]", "]"}]}]], ")"}]}], "+", 
        FractionBox["1", 
         RowBox[{"2", "Pi", " "}]]}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "Ord"}], "}"}]}], "]"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Derivative", "[", 
            RowBox[{
             RowBox[{"2", "k"}], "-", "1"}], "]"}], "[", "fHatS", "]"}], "[", 
          "0", "]"}], "==", "0"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", 
          RowBox[{"Ord", "+", "3"}]}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"D2", "=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       RowBox[{"n", "!"}]], 
      SuperscriptBox["z", "n"], 
      RowBox[{"CorrelatorD2", "[", "n", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "Ord"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T2List", "=", 
   RowBox[{"CoefficientList", "[", 
    RowBox[{"T2", ",", "z"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatchingList", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"MapIndexed", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "*", 
       RowBox[{"Factorial", "[", 
        RowBox[{
         RowBox[{"First", "[", "#2", "]"}], "-", "1"}], "]"}]}], "&"}], ",", 
     "T2List"}], "]"}], "]"}]}]}], "Input",
 InitializationCell->True,
