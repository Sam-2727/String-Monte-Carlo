  3.974224093049242*^9}},ExpressionUUID->"969a4bb2-d2fe-f243-8511-\
575949c1e62e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CompareRatios", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "l1p_", ",", "l2p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[Tau]", ",", "\[Tau]p", ",", "a", ",", "ap", ",", "logb", ",", "logbp",
       ",", "rd", ",", 
      RowBox[{"l3", "=", 
       RowBox[{
        RowBox[{"L", "/", "2"}], "-", "l1", "-", "l2"}]}], ",", " ", 
      RowBox[{"l3p", "=", 
       RowBox[{
        RowBox[{"L", "/", "2"}], "-", "l1p", "-", "l2p"}]}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{"a", "=", 
       RowBox[{"BoundaryIntercepts", "[", 
        RowBox[{"l1", ",", "l2", ",", "l3", ",", 
         RowBox[{"l1", "/", "2"}], ",", 
         RowBox[{"l2", "/", "2"}], ",", 
         RowBox[{"l3", "/", "2"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"logb", "=", 
      RowBox[{"a", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Tau]", "=", 
      RowBox[{"a", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"ap", "=", 
       RowBox[{"BoundaryIntercepts", "[", 
        RowBox[{"l1p", ",", "l2p", ",", "l3p", ",", 
         RowBox[{"l1p", "/", "2"}], ",", 
         RowBox[{"l2p", "/", "2"}], ",", 
         RowBox[{"l3p", "/", "2"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"logbp", "=", 
      RowBox[{"ap", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Tau]p", "=", 
      RowBox[{"ap", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"rd", "=", 
       RowBox[{"RatioDet", "[", 
        RowBox[{
        "L", ",", "l1", ",", "l2", ",", "l1p", ",", "l2p", ",", "\[Tau]", ",",
          "\[Tau]p"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rd", "[", 
         RowBox[{"[", "3", "]"}], "]"}], ",", 
        RowBox[{
         FractionBox["3", "36"], 
         RowBox[{"(", 
          RowBox[{"logbp", "-", "logb"}], ")"}]}]}], "}"}], "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
