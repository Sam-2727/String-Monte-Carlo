                RowBox[{"1", "/", "L"}]}], ")"}]}], "]"}], "]"}]}], "}"}], 
         ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"alpha", ",", "alphaMin", ",", "alphaMax", ",", "2"}], 
          "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"logDataSub", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Log", "[", 
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"Exp", "[", 
                  RowBox[{"I", " ", "Pi", " ", 
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "*", 
                    RowBox[{
                    RowBox[{"ells", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "/", "L"}]}], "+", 
                    RowBox[{"2", " ", 
                    RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "/", "L"}]}], "+", 
                    RowBox[{"1", "/", "L"}]}], ")"}]}], "]"}], "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"I", " ", "Pi", " ", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", "*", 
                    RowBox[{"ells", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], "+", "1"}], ")"}], "/", 
                    "L"}]}], "]"}]}], "]"}], "]"}], ",", 
              RowBox[{"Log", "[", 
               RowBox[{"Abs", "[", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}]}], "}"}], "&"}],
            "/@", 
           RowBox[{"Select", "[", 
            RowBox[{
             RowBox[{"vals", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{
              RowBox[{"fitLow", "<=", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "<=", "fitHigh"}], "&"}]}], 
            "]"}]}], ")"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"lm", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"LinearModelFit", "[", 
          RowBox[{
           RowBox[{"logDataSub", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", "x", ",", "x"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mean", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"lm", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<BestFitParameters\>\"", 
           "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"{", 
