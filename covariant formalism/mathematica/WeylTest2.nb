Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "RatioDet", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RatioDet", "[", 
   RowBox[{
   "L_", ",", "l11_", ",", "l12_", ",", "l21_", ",", "l22_", ",", "\[Tau]1_", 
    ",", "\[Tau]2_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "storedMat1", ",", "storedMat2", ",", "det1", ",", "storedMat22", ",", 
      "det2", ",", "Z1", ",", "Z2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"storedMat1", "=", 
      RowBox[{"DirectMatNFast", "[", 
       RowBox[{"L", ",", "100"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"storedMat2", "=", 
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l11", ",", "l12", ",", "storedMat1"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"det1", "=", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"logDetCholesky", "[", "storedMat2", "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"L", "/", "2"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"storedMat22", "=", 
      RowBox[{"DirectRedTracedMat", "[", 
       RowBox[{"L", ",", "l21", ",", "l22", ",", "storedMat1"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"det2", "=", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"logDetCholesky", "[", "storedMat22", "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"L", "/", "2"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Z1", "=", 
      RowBox[{"Z", "[", "\[Tau]1", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Z2", "=", 
      RowBox[{"Z", "[", "\[Tau]2", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "*", 
        RowBox[{"Log", "[", 
         RowBox[{"det2", "/", "det1"}], "]"}]}], ",", 
       RowBox[{"Log", "[", 
        RowBox[{"Z1", "/", "Z2"}], "]"}], ",", 
       RowBox[{"Log", "[", 
        RowBox[{
         SqrtBox[
          RowBox[{"det1", "/", "det2"}]], "*", 
         RowBox[{"Z1", "/", "Z2"}]}], "]"}]}], "}"}]}]}], "]"}]}]}], "Input",
 InitializationCell->True,
 CellLabel->"In[5]:=",ExpressionUUID->"1a5d8ea5-09c4-bd45-900c-eedad2bbc0dc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CompareRatiosImproved", "[", 
   RowBox[{"L_", ",", "l1_", ",", "l2_", ",", "l1p_", ",", "l2p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "cyl", ",", "cylp", ",", "\[Tau]", ",", "\[Tau]p", ",", "per", ",", 
      "perp", ",", "bs", ",", "bsp", ",", "logb", ",", "logbp", ",", 
      "logbAlt", ",", "logbpAlt", ",", "rd", ",", 
      RowBox[{"l3", "=", 
       RowBox[{
        RowBox[{"L", "/", "2"}], "-", "l1", "-", "l2"}]}], ",", " ", 
      RowBox[{"l3p", "=", 
       RowBox[{
        RowBox[{"L", "/", "2"}], "-", "l1p", "-", "l2p"}]}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"cyl", "=", 
      RowBox[{"CylEqnImproved", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"per", "=", 
      RowBox[{"PeriodsImproved", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", 
        RowBox[{
         RowBox[{"cyl", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", 
         RowBox[{"cyl", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Tau]", "=", 
      RowBox[{
       RowBox[{"per", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "/", 
       RowBox[{"per", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bs", " ", "=", " ", 
      RowBox[{"Calculateb", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", 
        RowBox[{"cyl", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"logb", "=", 
      RowBox[{"Log", "[", 
       RowBox[{"Mean", "[", 
        RowBox[{"Abs", "[", "bs", "]"}], "]"}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{"average", " ", "|", "b", "|", " ", 
       RowBox[{"first", " ", "then", " ", "take", " ", "log"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"logbAlt", "=", 
      RowBox[{"Log", "[", 
       RowBox[{"Mean", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"Averageb", "[", 
          RowBox[{"l1", ",", "l2", ",", "l3", ",", "bs"}], "]"}], "]"}], 
        "]"}], "]"}]}], ";", 
     RowBox[{"(*", 
      RowBox[{"use", " ", "smart", " ", "average"}], "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"cylp", "=", 
      RowBox[{"CylEqnImproved", "[", 
       RowBox[{"l1p", ",", "l2p", ",", "l3p", ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"perp", "=", 
      RowBox[{"PeriodsImproved", "[", 
       RowBox[{"l1p", ",", "l2p", ",", "l3p", ",", 
        RowBox[{
         RowBox[{"cylp", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "*", 
         RowBox[{"cylp", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Tau]p", "=", 
      RowBox[{
       RowBox[{"perp", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "/", 
       RowBox[{"perp", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bsp", " ", "=", " ", 
      RowBox[{"Calculateb", "[", 
       RowBox[{"l1p", ",", "l2p", ",", "l3p", ",", 
        RowBox[{"cylp", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", "z"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"logbp", "=", 
      RowBox[{"Log", "[", 
       RowBox[{"Mean", "[", 
        RowBox[{"Abs", "[", "bsp", "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"logbpAlt", "=", 
      RowBox[{"Log", "[", 
       RowBox[{"Mean", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"Averageb", "[", 
          RowBox[{"l1p", ",", "l2p", ",", "l3p", ",", "bsp"}], "]"}], "]"}], 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"rd", "=", 
       RowBox[{"RatioDet", "[", 
        RowBox[{
        "L", ",", "l1", ",", "l2", ",", "l1p", ",", "l2p", ",", "\[Tau]", ",",
          "\[Tau]p"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rd", "[", 
         RowBox[{"[", "3", "]"}], "]"}], ",", 
        RowBox[{
         FractionBox["3", "36"], 
         RowBox[{"(", 
          RowBox[{"logbp", "-", "logb"}], ")"}]}], ",", 
        RowBox[{
         FractionBox["3", "36"], 
         RowBox[{"(", 
          RowBox[{"logbpAlt", "-", "logbAlt"}], ")"}]}]}], "}"}], "]"}], 
     ";"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
