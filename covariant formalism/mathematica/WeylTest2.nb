 RowBox[{
  RowBox[{"Z", "[", "\[Tau]_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"Im", "[", "\[Tau]", "]"}], "^", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "*", 
   RowBox[{
    RowBox[{"Abs", "[", 
     RowBox[{"DedekindEta", "[", "\[Tau]", "]"}], "]"}], "^", 
