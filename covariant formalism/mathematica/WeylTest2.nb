Cell[BoxData[
 RowBox[{
  RowBox[{"logDetCholesky", "[", 
   RowBox[{"m_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "r", "}"}], ",", 
    RowBox[{
     RowBox[{"r", "=", 
      RowBox[{"CholeskyDecomposition", "[", "m", "]"}]}], ";", 
     RowBox[{"2", " ", 
      RowBox[{"Total", "[", 
       RowBox[{"Log", "[", 
        RowBox[{"Diagonal", "[", "r", "]"}], "]"}], "]"}]}]}]}], 
   "]"}]}]], "Input",
