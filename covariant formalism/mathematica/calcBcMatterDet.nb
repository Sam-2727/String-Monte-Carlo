  RowBox[{"(*", 
   RowBox[{"length", " ", "m"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"N", "[", 
   RowBox[{"coeffsM", ",", "30"}], "]"}], "//", "Short"}]}], "Input",
 CellChangeTimes->{
  3.979210248737701*^9},ExpressionUUID->"0d73e202-3e90-4315-af41-\
d03e4e76a7c2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"choose", " ", "L", " ", "and", " ", "fnum", " ", "beforehand"}], 
   "*)"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Example", ":", "L"}], "=", "234"}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"fnum", "=", 
     RowBox[{
      RowBox[{"CylEqnFastOptimized", "[", 
       RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}], "/.", " ", 
      RowBox[{
       RowBox[{"A", "[", "_", "]"}], "->", "0"}]}]}], ";"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"xMax", "=", 
     RowBox[{"L", "-", "1"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", "fw"}], "}"}], ",", 
         RowBox[{
          RowBox[{"w", "=", 
           RowBox[{"Exp", "[", 
            RowBox[{"4", " ", "I", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x", "+", "1"}], ")"}], "/", "L"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"fw", "=", 
           RowBox[{"fnum", "/.", " ", 
            RowBox[{"z", "->", "w"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Arg", "[", "w", "]"}], ",", 
            RowBox[{"Log", "[", 
             RowBox[{"Abs", "[", "fw", "]"}], "]"}]}], "}"}]}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "xMax", ",", "1"}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sort", " ", "by", " ", "Arg", " ", "so", " ", "the", " ", "plot", " ", 
     "is", " ", "ordered", " ", "nicely"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"valsSorted", "=", 
     RowBox[{"SortBy", "[", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{"vals", ",", 
         RowBox[{
          RowBox[{"FreeQ", "[", 
           RowBox[{"#", ",", 
            RowBox[{
            "Indeterminate", "|", "ComplexInfinity", "|", "Infinity", "|", 
             RowBox[{"-", "Infinity"}]}]}], "]"}], "&"}]}], "]"}], ",", 
       "First"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"valsSorted", ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"PointSize", "[", "0.012", "]"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Arg(w)\>\"", ",", "\"\<Log|f(w)|\>\""}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{3.979207890412672*^9},
 CellLabel->
  "In[192]:=",ExpressionUUID->"90dfc618-56a2-476e-81bd-e6d115f71fd6"],

