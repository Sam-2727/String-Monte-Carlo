Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Parameters", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "Parameters", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"alphaMin", "=", 
     RowBox[{"-", "40"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphaMax", "=", "0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"step", "=", "2"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"fitLow", "=", 
     RowBox[{"-", "4"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"fitHigh", "=", 
     RowBox[{"-", "1"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ell", "=", "l1"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"w0", "=", 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "Pi", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2.0", " ", "ell"}], "+", "1.0"}], ")"}], "/", "L"}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Build", " ", "log"}], "-", 
     RowBox[{"log", " ", 
      RowBox[{"data", ":", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Log", "|", 
           RowBox[{"w", "-", "w0"}], "|"}], ",", 
          RowBox[{"Log", "|", 
           RowBox[{"f", 
            RowBox[{"(", "w", ")"}]}], "|"}]}], "}"}], " ", "for", " ", 
        "each", " ", "alpha"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", ",", "fw", ",", "dx", ",", "dy"}], "}"}], ",", 
         RowBox[{
          RowBox[{"w", "=", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "Pi", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2.0", " ", 
                RowBox[{"ell", "/", "L"}]}], "+", 
               RowBox[{"2.0", " ", 
                RowBox[{"alpha", "/", "L"}]}], "+", 
               RowBox[{"1.0", "/", "L"}]}], ")"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"fw", "=", 
           RowBox[{"(", 
            RowBox[{"fnum", "/.", " ", 
             RowBox[{"z", "->", "w"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
          
          RowBox[{"dx", "=", 
           RowBox[{"Abs", "[", 
            RowBox[{"w", "-", "w0"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"dy", "=", 
           RowBox[{"Abs", "[", "fw", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"alpha", ",", 
            RowBox[{"Log", "[", "dx", "]"}], ",", 
            RowBox[{"Log", "[", "dy", "]"}]}], "}"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"alpha", ",", "alphaMin", ",", "alphaMax", ",", "step"}], 
        "}"}]}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Drop", " ", "any", " ", "non"}], "-", 
     RowBox[{"finite", " ", "points", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"e", ".", "g", ".", 
         RowBox[{"Log", "[", "0", "]"}]}], "->", 
        RowBox[{"-", "Infinity"}]}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"valsFinite", "=", 
     RowBox[{"Select", "[", 
      RowBox[{"vals", ",", 
       RowBox[{
        RowBox[{"FreeQ", "[", 
         RowBox[{"#", ",", 
          RowBox[{"ComplexInfinity", "|", "Indeterminate", "|", "Infinity", "|", 
           RowBox[{"-", "Infinity"}]}]}], "]"}], "&"}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Points", " ", "used", " ", "for", " ", "the", " ", "fit", " ", 
     "window"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fitData", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "3", "]"}], "]"}]}], "}"}], "&"}], "/@", 
       RowBox[{"Select", "[", 
        RowBox[{"valsFinite", ",", 
         RowBox[{
          RowBox[{"fitLow", "<=", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "<=", "fitHigh"}], "&"}]}], 
        "]"}]}], ")"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Linear", " ", "fit", " ", "y"}], "=", 
     RowBox[{"a", "+", 
      RowBox[{"b", " ", "x"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lm", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"fitData", ",", "x", ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"params", "=", 
     RowBox[{"lm", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"Intercept", "->", "a"}], ",", 
       RowBox[{"x", "->", "b"}]}], "|>"}], " ", "or", " ", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], " ", "depending", " ", "on", " ", 
     "version"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Best fit parameters: \>\"", ",", "params"}], "]"}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Extract", " ", "intercept", " ", "and", " ", "slope", " ", "robustly"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"a", "=", 
     RowBox[{
      RowBox[{"lm", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"b", "=", 
     RowBox[{
      RowBox[{"lm", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Intercept a = \>\"", ",", "a"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Slope b = \>\"", ",", "b"}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Plot", ":", 
     RowBox[{
      RowBox[{"all", " ", "points"}], "+", 
      RowBox[{
      "best", " ", "fit", " ", "line", " ", "over", " ", "the", " ", "fit"}], 
      "-", 
      RowBox[{"x", " ", "range"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xMin", "=", 
     RowBox[{"Min", "[", 
      RowBox[{"fitData", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xMax", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"fitData", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "3", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         "valsFinite"}], ")"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Log|w-w0|\>\"", ",", "\"\<Log|f(w)|\>\""}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"lm", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "xMin", ",", "xMax"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", "Thick", "}"}]}]}], "]"}]}], "]"}]}]}]], "Input",
