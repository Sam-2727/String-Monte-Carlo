       RowBox[{"\"\<WorkingPrecision\>\"", "->", "100"}]}], "]"}]}], ";"}], 
   "  ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fnum2", "=", 
     RowBox[{"CylEqn", "[", 
      RowBox[{"l1", ",", "l2", ",", "l3", ",", "z"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
