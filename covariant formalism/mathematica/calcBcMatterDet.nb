Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"n", "=", "400"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"triples", "=", 
    RowBox[{"Reverse", "[", 
     RowBox[{"IntegerPartitions", "[", 
      RowBox[{"n", ",", 
       RowBox[{"{", "3", "}"}], ",", 
       RowBox[{"Range", "[", 
        RowBox[{"2", ",", "n", ",", "2"}], "]"}]}], "]"}], "]"}]}], ";"}], 
  "   ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"each", " ", "is", " ", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b", ",", "c"}], "}"}], " ", "with", " ", "a"}], ">=",
     "b", ">=", "c"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rhsArray", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0.", ",", 
     RowBox[{"{", 
      RowBox[{"Length", "[", "triples", "]"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lhsArray", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0.", ",", 
     RowBox[{"{", 
      RowBox[{"Length", "[", "triples", "]"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.978693108253501*^9, 3.978693123497328*^9}, {
  3.9786932304993677`*^9, 3.978693231026723*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"3327baf8-43a1-4ccf-b41c-a3f58f44f617"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "manually", " ", "abort", " ", "this", " ", "at", " ", "some", " ", 
     "iteration"}], ",", " ", 
    RowBox[{"usually", " ", "around", " ", "30"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "<=", 
     RowBox[{"Length", "[", "triples", "]"}]}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c"}], "}"}], "=", 
      RowBox[{"triples", "[", 
       RowBox[{"[", 
        RowBox[{"i", "*", "10"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"j", "=", 
      RowBox[{"i", "*", "10"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lhsNum", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"Bdet", "[", 
          RowBox[{
           RowBox[{"2", " ", "n"}], ",", "a", ",", "b"}], "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"primeDet", "[", 
          RowBox[{
           RowBox[{"2", " ", "n"}], ",", "a", ",", "b"}], "]"}], "^", 
         RowBox[{"(", 
          RowBox[{"-", "13"}], ")"}]}]}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhsNum", "=", 
      RowBox[{"computeRHS", "[", 
       RowBox[{
        RowBox[{"a", "+", "1"}], ",", 
        RowBox[{"b", "+", "1"}], ",", 
        RowBox[{"c", "+", "1"}], ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"a", "+", "1"}], ")"}], "/", "2"}], "]"}], ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"b", "+", "1"}], ")"}], "/", "2"}], "]"}], ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"c", "+", "1"}], ")"}], "/", "2"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mod", "[", 
         RowBox[{"i", ",", "10"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Print", "[", "i", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"rhsArray", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "=", "rhsNum"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"lhsArray", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "=", "lhsNum"}], ";"}]}], 
   "]"}]}]], "Input",
