Cell[BoxData[{
 RowBox[{
  RowBox[{"poly", "=", 
   RowBox[{"CylEqnFastOptimized", "[", 
    RowBox[{"l1", ",", "l2", ",", "l3", ",", "z", ",", 
     RowBox[{"\"\<WorkingPrecision\>\"", "->", "100"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"coeffsM", "=", 
    RowBox[{"CoefficientList", "[", 
