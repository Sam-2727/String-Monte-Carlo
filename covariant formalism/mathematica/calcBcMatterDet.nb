  RowBox[{
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"13", "*", "2", "*", "15"}]}], ";"}], "          ", 
   RowBox[{"(*", " ", 
    RowBox[{"=", "234"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"l1", "=", 
     RowBox[{"3", "*", "15"}]}], ";"}], "            ", 
   RowBox[{"(*", " ", 
    RowBox[{"=", "9"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"l2", "=", 
     RowBox[{"1", "*", "15"}]}], ";"}], "            ", 
   RowBox[{"(*", " ", 
    RowBox[{"=", "81"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"l3", "=", 
     RowBox[{
      RowBox[{"L", "/", "2"}], "-", "l1", "-", "l2"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"if", " ", "you", " ", "need", " ", "it"}], ";", 
