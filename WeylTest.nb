    RowBox[{"{", 
     RowBox[{"WorkingPrecision", "->", "200"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"CylEqnFastOptimized", "[", 
   RowBox[{"l1_", ",", "l2_", ",", "l3_", ",", "z_", ",", 
    RowBox[{"opts", ":", 
     RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"wp", "=", "100"}], ",", "L", ",", "m", ",", "nList", ",", 
      "anglesL", ",", "anglesR", ",", "B", ",", "gram", ",", "rhsVec", ",", 
      "coeffs"}], "}"}], ",", 
    RowBox[{
     RowBox[{"L", "=", 
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{"l1", "+", "l2", "+", "l3"}], ")"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"m", "=", 
      RowBox[{"L", "/", "2"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nList", "=", 
      RowBox[{"Range", "[", "m", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesL", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"L", "/", "2"}], "+", "l1", "+", "1", "-", "k"}], 
               ")"}], "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", "1", ",", "l1"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"L", "/", "2"}], "+", 
                RowBox[{"2", " ", "l1"}], "+", "l2", "+", "1", "-", "k"}], 
               ")"}], "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "1"}], ",", 
              RowBox[{"l1", "+", "l2"}]}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"2", " ", "Pi", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"L", "+", "l1", "+", "l2", "+", "1", "-", "k"}], ")"}],
               "/", "L"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"l1", "+", "l2", "+", "1"}], ",", "m"}], "}"}]}], 
           "]"}]}], "]"}], ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"anglesR", "=", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"2", " ", "Pi", " ", 
           RowBox[{"k", "/", "L"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "m"}], "}"}]}], "]"}], ",", "wp"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"B", "=", 
      RowBox[{"Developer`ToPackedArray", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", 
           RowBox[{"Outer", "[", 
            RowBox[{"Times", ",", "anglesL", ",", "nList"}], "]"}]}], "]"}], 
         "+", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", 
           RowBox[{"Outer", "[", 
            RowBox[{"Times", ",", 
             RowBox[{"Take", "[", 
              RowBox[{"anglesR", ",", 
               RowBox[{"Length", "[", "anglesL", "]"}]}], "]"}], ",", 
             "nList"}], "]"}]}], "]"}]}], ",", "Complex"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"gram", "=", 
      RowBox[{
       RowBox[{"Transpose", "[", "B", "]"}], ".", "B"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"gram", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "+=", 
      RowBox[{"SetPrecision", "[", 
       RowBox[{"1", ",", "wp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhsVec", "=", 
