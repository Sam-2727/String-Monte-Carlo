       RowBox[{"Log", "[", 
        RowBox[{"Z1", "/", "Z2"}], "]"}], ",", 
       RowBox[{"Log", "[", 
        RowBox[{
         SqrtBox[
          RowBox[{"det1", "/", "det2"}]], "*", 
