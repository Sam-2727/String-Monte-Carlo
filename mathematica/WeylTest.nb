   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "alphaMin", ",", "alphaMax", ",", "fitLow", ",", "fitHigh", ",", "vals",
        ",", "logDataSub", ",", "lm"}], "}"}], ",", 
     RowBox[{
      RowBox[{"alphaMin", "=", 
       RowBox[{"-", "40"}]}], ";", 
