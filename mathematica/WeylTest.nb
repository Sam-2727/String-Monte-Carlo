           RowBox[{"f", "[", 
            RowBox[{"Exp", "[", 
             RowBox[{"I", " ", "Pi", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", "*", 
                 RowBox[{"k0", "/", "L"}]}], "+", 
                RowBox[{"2", 
                 RowBox[{"alpha", "/", "L"}]}], "+", 
                RowBox[{"1", "/", "L"}]}], ")"}]}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"alpha", ",", "alphaMin", ",", "alphaMax", ",", "2"}], 
          "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"logDataSub", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
