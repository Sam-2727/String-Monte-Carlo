         RowBox[{"Select", "[", 
          RowBox[{"vals", ",", 
           RowBox[{
            RowBox[{"fitLow", "<=", 
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "<=", "fitHigh"}], "&"}]}], 
          "]"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"lm", "=", 
