Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RedMMatrixN", "[", 
    RowBox[{"{", 
     RowBox[{"L1_", ",", "L2_"}], "}"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Mkernel", ",", "Mkernel1", ",", "Mkernel2", ",", "LastRow", ",", "k1", 
       ",", "k2", ",", "M", ",", 
       RowBox[{"L", "=", 
        RowBox[{"L1", "+", "L2"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Mkernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mkernel1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L1", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L1", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mkernel2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L2", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L2", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"k1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"k", "*", 
          RowBox[{
           RowBox[{"\[Chi]", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", "k", 
           "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"k2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"k", "-", "L1"}], ")"}], "*", 
          RowBox[{
           RowBox[{"\[Chi]", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", "k", 
           "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"LastRow", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Pi", "*", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              FractionBox["1", 
               RowBox[{"Pi", "*", "L"}]], 
              RowBox[{"Mkernel", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"Mod", "[", 
                  RowBox[{
                   RowBox[{"k", "-", "L"}], ",", "L"}], "]"}], "+", "1"}], 
                "]"}], "]"}]}], "+", 
             RowBox[{
              FractionBox[
               RowBox[{
                RowBox[{
                 RowBox[{"\[Chi]", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", 
                 "k", "]"}], 
                RowBox[{
                 RowBox[{"\[Chi]", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", 
                 "L", "]"}]}], 
               RowBox[{"Pi", "*", "L1"}]], 
              RowBox[{"Mkernel1", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"Mod", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"k1", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "-", 
                    RowBox[{"k1", "[", 
                    RowBox[{"[", "L", "]"}], "]"}]}], ",", "L1"}], "]"}], "+",
                  "1"}], "]"}], "]"}]}], "+", 
             RowBox[{
              FractionBox[
               RowBox[{
                RowBox[{
                 RowBox[{"\[Chi]", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", 
                 "k", "]"}], 
                RowBox[{
                 RowBox[{"\[Chi]", "[", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", 
                 "L", "]"}]}], 
               RowBox[{"Pi", "*", "L2"}]], 
              RowBox[{"Mkernel2", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"Mod", "[", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"k2", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "-", 
                    RowBox[{"k2", "[", 
                    RowBox[{"[", "L", "]"}], "]"}]}], ",", "L2"}], "]"}], "+",
                  "1"}], "]"}], "]"}]}]}], ",", "prec"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"M", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "multiply", " ", "by", " ", "Pi", " ", "to", " ", "kill", " ", 
          "exponential", " ", "scaling", " ", "of", " ", "det"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Pi", "*", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               FractionBox["1", 
                RowBox[{"Pi", "*", "L"}]], 
               RowBox[{"Mkernel", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{"k", "-", "l"}], ",", "L"}], "]"}], "+", "1"}], 
                 "]"}], "]"}]}], "+", 
              RowBox[{
               FractionBox[
                RowBox[{
                 RowBox[{
                  RowBox[{"\[Chi]", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", 
                  "k", "]"}], 
                 RowBox[{
                  RowBox[{"\[Chi]", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", 
                  "l", "]"}]}], 
                RowBox[{"Pi", "*", "L1"}]], 
               RowBox[{"Mkernel1", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"k1", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "-", 
                    RowBox[{"k1", "[", 
                    RowBox[{"[", "l", "]"}], "]"}]}], ",", "L1"}], "]"}], "+",
                   "1"}], "]"}], "]"}]}], "+", 
              RowBox[{
               FractionBox[
                RowBox[{
                 RowBox[{
                  RowBox[{"\[Chi]", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", 
                  "k", "]"}], 
                 RowBox[{
                  RowBox[{"\[Chi]", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", 
                  "l", "]"}]}], 
                RowBox[{"Pi", "*", "L2"}]], 
               RowBox[{"Mkernel2", "[", 
                RowBox[{"[", 
                 RowBox[{
                  RowBox[{"Mod", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"k2", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "-", 
                    RowBox[{"k2", "[", 
                    RowBox[{"[", "l", "]"}], "]"}]}], ",", "L2"}], "]"}], "+",
                   "1"}], "]"}], "]"}]}]}], ",", "prec"}], "]"}]}], "-", 
          RowBox[{"LastRow", "[", 
           RowBox[{"[", "k", "]"}], "]"}], "-", 
          RowBox[{"LastRow", "[", 
           RowBox[{"[", "l", "]"}], "]"}], "+", 
          RowBox[{"LastRow", "[", 
           RowBox[{"[", "L", "]"}], "]"}]}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"l", ",", "1", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
