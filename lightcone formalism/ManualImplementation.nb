Cell[CellGroupData[{

Cell["Fixing wavefunctional normalization and showing eigenvalues", \
"Subsection",
 CellChangeTimes->{{3.9821887725155582`*^9, 
  3.982188794197155*^9}},ExpressionUUID->"ef769cc8-4a2e-3c4e-887c-\
caebb0520870"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"singleMMatrixN", "[", 
    RowBox[{"{", 
     RowBox[{"L1_", ",", "L2_"}], "}"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Mkernel", ",", "Mkernel1", ",", "Mkernel2", ",", "k1", ",", "k2", ",", 
       "M", ",", 
       RowBox[{"L", "=", 
        RowBox[{"L1", "+", "L2"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Mkernel", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mkernel1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L1", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L1", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Mkernel2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"Mkernelfunc", "[", 
            RowBox[{"L2", ",", "x"}], "]"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "0", ",", 
           RowBox[{"L2", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"k1", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"k", "*", 
          RowBox[{
           RowBox[{"\[Chi]", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"L1", ",", "L2"}], "}"}], ",", "1"}], "]"}], "[", "k", 
           "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"k2", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"k", "-", "L1"}], ")"}], "*", 
          RowBox[{
           RowBox[{"\[Chi]", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"L1", ",", "L2"}], "}"}], ",", "2"}], "]"}], "[", "k", 
           "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"M", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "multiply", " ", "by", " ", "Pi", " ", "to", " ", "kill", " ", 
          "exponential", " ", "scaling", " ", "of", " ", "det"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Pi", "*", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{
             FractionBox["2", 
              RowBox[{"Pi", "*", "L"}]], 
             RowBox[{"Mkernel", "[", 
              RowBox[{"[", 
               RowBox[{
                RowBox[{"Mod", "[", 
                 RowBox[{
                  RowBox[{"k", "-", "l"}], ",", "L"}], "]"}], "+", "1"}], 
               "]"}], "]"}]}], ",", "prec"}], "]"}]}], "\[IndentingNewLine]", 
         ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", "L"}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"l", ",", "1", ",", "L"}], "}"}]}], "]"}]}], ";", 
